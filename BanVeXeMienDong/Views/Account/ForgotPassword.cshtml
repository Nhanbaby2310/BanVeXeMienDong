@{
    ViewData["Title"] = "Quên Mật Khẩu";
}

<div class="min-h-[calc(100vh-200px)] flex items-center justify-center py-12 px-4">
    <div class="w-full max-w-md">
        <!-- Card -->
        <div class="bg-white rounded-2xl shadow-xl border border-gray-100 overflow-hidden">
            <!-- Header -->
            <div class="bg-gradient-to-br from-amber-500 to-orange-600 px-8 py-8 text-center">
                <div class="w-16 h-16 mx-auto bg-white/20 backdrop-blur-sm rounded-2xl flex items-center justify-center mb-4">
                    <i class="bi bi-key text-3xl text-white"></i>
                </div>
                <h1 class="text-2xl font-bold text-white">Quên Mật Khẩu</h1>
                <p class="text-amber-100 text-sm mt-1">Lấy lại mật khẩu của bạn</p>
            </div>

            <!-- Form -->
            <div class="p-8">
                @if (!string.IsNullOrEmpty(ViewBag.Error))
                {
                    <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-xl text-sm mb-4 flex items-center gap-2">
                        <i class="bi bi-exclamation-circle"></i> @ViewBag.Error
                    </div>
                }

                @if (!string.IsNullOrEmpty(ViewBag.Success))
                {
                    <div class="bg-green-50 border border-green-200 text-green-700 px-4 py-3 rounded-xl text-sm mb-4 flex items-center gap-2">
                        <i class="bi bi-check-circle"></i> @ViewBag.Success
                    </div>
                }

                @if (ViewBag.ShowResetForm == true)
                {
                    <!-- Reset Form -->
                    <p class="text-sm text-gray-600 mb-5 text-center">Nhập mã đặt lại và mật khẩu mới:</p>

                    <form method="post" action="/Account/ResetPassword">
                        <input type="hidden" name="username" value="@ViewBag.Username" />

                        <div class="mb-4">
                            <label class="block text-sm font-semibold text-gray-700 mb-2">Mã đặt lại</label>
                            <input type="text" name="token"
                                class="w-full px-4 py-3 border-2 border-gray-200 rounded-xl text-sm text-center font-mono font-bold tracking-widest uppercase focus:border-amber-500 focus:ring-4 focus:ring-amber-100 transition-all"
                                placeholder="XXXXXXXX" required maxlength="8" />
                        </div>

                        <div class="mb-4">
                            <label class="block text-sm font-semibold text-gray-700 mb-2">Mật khẩu mới</label>
                            <div class="relative">
                                <i class="bi bi-lock absolute left-4 top-1/2 -translate-y-1/2 text-gray-400"></i>
                                <input type="password" name="newPassword"
                                    class="w-full pl-11 pr-4 py-3 border-2 border-gray-200 rounded-xl text-sm focus:border-amber-500 focus:ring-4 focus:ring-amber-100 transition-all"
                                    placeholder="Tối thiểu 6 ký tự" required minlength="6" />
                            </div>
                        </div>

                        <div class="mb-6">
                            <label class="block text-sm font-semibold text-gray-700 mb-2">Xác nhận mật khẩu</label>
                            <div class="relative">
                                <i class="bi bi-lock-fill absolute left-4 top-1/2 -translate-y-1/2 text-gray-400"></i>
                                <input type="password" name="confirmPassword"
                                    class="w-full pl-11 pr-4 py-3 border-2 border-gray-200 rounded-xl text-sm focus:border-amber-500 focus:ring-4 focus:ring-amber-100 transition-all"
                                    placeholder="Nhập lại mật khẩu mới" required />
                            </div>
                        </div>

                        <button type="submit" class="w-full py-3.5 bg-gradient-to-r from-amber-500 to-orange-600 hover:from-amber-600 hover:to-orange-700 text-white font-semibold rounded-xl shadow-lg hover:shadow-xl transition-all hover:-translate-y-0.5">
                            <i class="bi bi-check-circle me-2"></i> Đặt Lại Mật Khẩu
                        </button>
                    </form>
                }
                else
                {
                    <!-- Request Form -->
                    <p class="text-sm text-gray-600 mb-5 text-center">Nhập tài khoản và email đã đăng ký để nhận mã đặt lại.</p>

                    <form method="post">
                        <div class="mb-4">
                            <label class="block text-sm font-semibold text-gray-700 mb-2">Tài khoản</label>
                            <div class="relative">
                                <i class="bi bi-person absolute left-4 top-1/2 -translate-y-1/2 text-gray-400"></i>
                                <input type="text" name="username"
                                    class="w-full pl-11 pr-4 py-3 border-2 border-gray-200 rounded-xl text-sm focus:border-amber-500 focus:ring-4 focus:ring-amber-100 transition-all"
                                    placeholder="Tên đăng nhập" required />
                            </div>
                        </div>

                        <div class="mb-6">
                            <label class="block text-sm font-semibold text-gray-700 mb-2">Email đã đăng ký</label>
                            <div class="relative">
                                <i class="bi bi-envelope absolute left-4 top-1/2 -translate-y-1/2 text-gray-400"></i>
                                <input type="email" name="email"
                                    class="w-full pl-11 pr-4 py-3 border-2 border-gray-200 rounded-xl text-sm focus:border-amber-500 focus:ring-4 focus:ring-amber-100 transition-all"
                                    placeholder="example@email.com" required />
                            </div>
                        </div>

                        <button type="submit" class="w-full py-3.5 bg-gradient-to-r from-amber-500 to-orange-600 hover:from-amber-600 hover:to-orange-700 text-white font-semibold rounded-xl shadow-lg hover:shadow-xl transition-all hover:-translate-y-0.5">
                            <i class="bi bi-send me-2"></i> Gửi Mã Đặt Lại
                        </button>
                    </form>
                }
            </div>
        </div>

        <!-- Back to Login -->
        <div class="text-center mt-6">
            <a href="/Account/Login" class="text-sm text-gray-600 hover:text-blue-600 font-medium">
                <i class="bi bi-arrow-left me-1"></i> Quay lại Đăng nhập
            </a>
        </div>
    </div>
</div>
