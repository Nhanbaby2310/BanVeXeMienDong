@{
    ViewData["Title"] = "Đăng nhập";
}

<div class="min-h-[calc(100vh-200px)] flex items-center justify-center py-12 px-4">
    <div class="w-full max-w-md">
        <!-- Card -->
        <div class="bg-white rounded-2xl shadow-xl border border-gray-100 overflow-hidden">
            <!-- Header -->
            <div class="gradient-primary px-8 py-8 text-center">
                <div class="w-16 h-16 mx-auto bg-white/20 backdrop-blur-sm rounded-2xl flex items-center justify-center mb-4">
                    <i class="bi bi-person-circle text-3xl text-white"></i>
                </div>
                <h1 class="text-2xl font-bold text-white">Đăng Nhập</h1>
                <p class="text-blue-100 text-sm mt-1">Chào mừng bạn trở lại!</p>
            </div>

            <!-- Form -->
            <div class="p-8">
                @if (!string.IsNullOrEmpty(ViewBag.Error))
                {
                    <div data-toast-error="@ViewBag.Error" class="hidden"></div>
                    <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-xl text-sm mb-4 flex items-center gap-2">
                        <i class="bi bi-exclamation-circle"></i> @ViewBag.Error
                    </div>
                }

                @if (TempData["Success"] != null)
                {
                    <div data-toast-success="@TempData["Success"]" class="hidden"></div>
                    <div class="bg-green-50 border border-green-200 text-green-700 px-4 py-3 rounded-xl text-sm mb-4 flex items-center gap-2">
                        <i class="bi bi-check-circle"></i> @TempData["Success"]
                    </div>
                }

                <form method="post">
                    @Html.AntiForgeryToken()

                    <div class="mb-5">
                        <label for="username" class="block text-sm font-semibold text-gray-700 mb-2">Tài khoản</label>
                        <div class="relative">
                            <i class="bi bi-person absolute left-4 top-1/2 -translate-y-1/2 text-gray-400"></i>
                            <input type="text" id="username" name="Username"
                                class="w-full pl-11 pr-4 py-3 border-2 border-gray-200 rounded-xl text-sm focus:border-blue-500 focus:ring-4 focus:ring-blue-100 transition-all"
                                placeholder="Nhập tên đăng nhập" required />
                        </div>
                    </div>

                    <div class="mb-5">
                        <label for="password" class="block text-sm font-semibold text-gray-700 mb-2">Mật khẩu</label>
                        <div class="relative">
                            <i class="bi bi-lock absolute left-4 top-1/2 -translate-y-1/2 text-gray-400"></i>
                            <input type="password" id="password" name="Password"
                                class="w-full pl-11 pr-4 py-3 border-2 border-gray-200 rounded-xl text-sm focus:border-blue-500 focus:ring-4 focus:ring-blue-100 transition-all"
                                placeholder="Nhập mật khẩu" required />
                        </div>
                    </div>

                    <div class="flex items-center justify-between mb-6">
                        <label class="flex items-center gap-2 cursor-pointer">
                            <input type="checkbox" class="w-4 h-4 rounded border-gray-300 text-blue-600 focus:ring-blue-500">
                            <span class="text-sm text-gray-600">Ghi nhớ đăng nhập</span>
                        </label>
                        <a href="/Account/ForgotPassword" class="text-sm text-blue-600 hover:text-blue-800 font-medium">Quên mật khẩu?</a>
                    </div>

                    <button type="submit" class="w-full py-3.5 bg-gradient-to-r from-blue-600 to-blue-700 hover:from-blue-700 hover:to-blue-800 text-white font-semibold rounded-xl shadow-lg hover:shadow-xl transition-all hover:-translate-y-0.5">
                        <i class="bi bi-box-arrow-in-right me-2"></i> Đăng Nhập
                    </button>
                </form>
            </div>
        </div>

        <!-- Register Link -->
        <div class="text-center mt-6">
            <p class="text-gray-600 text-sm">
                Chưa có tài khoản?
                <a href="/Account/Register" class="text-blue-600 hover:text-blue-800 font-semibold ml-1">Đăng ký ngay</a>
            </p>
        </div>
    </div>
</div>
