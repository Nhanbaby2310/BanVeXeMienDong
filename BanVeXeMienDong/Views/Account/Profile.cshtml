@model BanVeXeMienDong.Models.User

@{
    ViewData["Title"] = "Hồ Sơ Cá Nhân";
}

<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <h1 class="text-2xl font-bold text-gray-900 mb-6"><i class="bi bi-person-circle text-blue-600"></i> Hồ Sơ Cá Nhân</h1>

    @if (TempData["Success"] != null)
    {
        <div data-toast-success="@TempData["Success"]"></div>
    }
    @if (TempData["Error"] != null)
    {
        <div data-toast-error="@TempData["Error"]"></div>
    }

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <!-- Personal Info -->
        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6">
            <h3 class="font-bold text-gray-900 mb-5 flex items-center gap-2">
                <i class="bi bi-person-badge text-blue-600"></i> Thông Tin Cá Nhân
            </h3>

            <form method="post" action="/Account/Profile">
                <div class="space-y-4">
                    <div>
                        <label class="block text-xs font-semibold text-gray-500 uppercase mb-1">Tài khoản</label>
                        <input type="text" value="@Model.Username" disabled
                            class="w-full px-4 py-2.5 bg-gray-50 border border-gray-200 rounded-xl text-sm text-gray-500">
                    </div>

                    <div>
                        <label class="block text-xs font-semibold text-gray-500 uppercase mb-1">Vai trò</label>
                        <div class="inline-flex px-3 py-1 rounded-full text-xs font-bold @(Model.Role == "Admin" ? "bg-red-100 text-red-700" : "bg-blue-100 text-blue-700")">
                            @Model.Role
                        </div>
                    </div>

                    <div>
                        <label class="block text-xs font-semibold text-gray-500 uppercase mb-1">Họ và tên</label>
                        <input type="text" name="fullName" value="@Model.FullName" placeholder="Nhập họ và tên"
                            class="w-full px-4 py-2.5 border-2 border-gray-200 rounded-xl text-sm focus:border-blue-500 focus:ring-4 focus:ring-blue-100 transition-all">
                    </div>

                    <div>
                        <label class="block text-xs font-semibold text-gray-500 uppercase mb-1">Email</label>
                        <input type="email" name="email" value="@Model.Email" placeholder="example@email.com"
                            class="w-full px-4 py-2.5 border-2 border-gray-200 rounded-xl text-sm focus:border-blue-500 focus:ring-4 focus:ring-blue-100 transition-all">
                    </div>

                    <div>
                        <label class="block text-xs font-semibold text-gray-500 uppercase mb-1">Số điện thoại</label>
                        <input type="tel" name="phone" value="@Model.Phone" placeholder="0123 456 789"
                            class="w-full px-4 py-2.5 border-2 border-gray-200 rounded-xl text-sm focus:border-blue-500 focus:ring-4 focus:ring-blue-100 transition-all">
                    </div>
                </div>

                <button type="submit" class="mt-5 w-full py-3 bg-blue-600 hover:bg-blue-700 text-white font-semibold rounded-xl shadow-sm transition-all">
                    <i class="bi bi-check-lg me-1"></i> Lưu Thay Đổi
                </button>
            </form>
        </div>

        <!-- Change Password -->
        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6">
            <h3 class="font-bold text-gray-900 mb-5 flex items-center gap-2">
                <i class="bi bi-shield-lock text-amber-600"></i> Đổi Mật Khẩu
            </h3>

            <form method="post" action="/Account/ChangePassword">
                <div class="space-y-4">
                    <div>
                        <label class="block text-xs font-semibold text-gray-500 uppercase mb-1">Mật khẩu hiện tại</label>
                        <input type="password" name="currentPassword" required
                            class="w-full px-4 py-2.5 border-2 border-gray-200 rounded-xl text-sm focus:border-amber-500 focus:ring-4 focus:ring-amber-100 transition-all">
                    </div>

                    <div>
                        <label class="block text-xs font-semibold text-gray-500 uppercase mb-1">Mật khẩu mới</label>
                        <input type="password" name="newPassword" required minlength="6"
                            class="w-full px-4 py-2.5 border-2 border-gray-200 rounded-xl text-sm focus:border-amber-500 focus:ring-4 focus:ring-amber-100 transition-all">
                        <p class="text-xs text-gray-400 mt-1">Tối thiểu 6 ký tự</p>
                    </div>

                    <div>
                        <label class="block text-xs font-semibold text-gray-500 uppercase mb-1">Xác nhận mật khẩu mới</label>
                        <input type="password" name="confirmNewPassword" required
                            class="w-full px-4 py-2.5 border-2 border-gray-200 rounded-xl text-sm focus:border-amber-500 focus:ring-4 focus:ring-amber-100 transition-all">
                    </div>
                </div>

                <button type="submit" class="mt-5 w-full py-3 bg-amber-500 hover:bg-amber-600 text-white font-semibold rounded-xl shadow-sm transition-all">
                    <i class="bi bi-key me-1"></i> Đổi Mật Khẩu
                </button>
            </form>
        </div>
    </div>

    <!-- Quick Links -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mt-8">
        <a href="/Checkout/MyOrders" class="group bg-white rounded-xl border border-gray-100 shadow-sm p-5 flex items-center gap-4 hover:shadow-md hover:border-blue-200 transition-all">
            <div class="w-12 h-12 rounded-xl bg-blue-100 flex items-center justify-center group-hover:bg-blue-200 transition-colors">
                <i class="bi bi-receipt text-xl text-blue-600"></i>
            </div>
            <div>
                <div class="font-semibold text-gray-900 text-sm">Đơn Hàng</div>
                <div class="text-xs text-gray-400">Xem lịch sử đặt vé</div>
            </div>
        </a>

        <a href="/Cart/Index" class="group bg-white rounded-xl border border-gray-100 shadow-sm p-5 flex items-center gap-4 hover:shadow-md hover:border-blue-200 transition-all">
            <div class="w-12 h-12 rounded-xl bg-green-100 flex items-center justify-center group-hover:bg-green-200 transition-colors">
                <i class="bi bi-bag text-xl text-green-600"></i>
            </div>
            <div>
                <div class="font-semibold text-gray-900 text-sm">Giỏ Hàng</div>
                <div class="text-xs text-gray-400">Xem giỏ hàng hiện tại</div>
            </div>
        </a>

        <a href="/Ticket/SelectRoute" class="group bg-white rounded-xl border border-gray-100 shadow-sm p-5 flex items-center gap-4 hover:shadow-md hover:border-blue-200 transition-all">
            <div class="w-12 h-12 rounded-xl bg-purple-100 flex items-center justify-center group-hover:bg-purple-200 transition-colors">
                <i class="bi bi-ticket-perforated text-xl text-purple-600"></i>
            </div>
            <div>
                <div class="font-semibold text-gray-900 text-sm">Đặt Vé</div>
                <div class="text-xs text-gray-400">Tìm chuyến xe mới</div>
            </div>
        </a>
    </div>
</div>
