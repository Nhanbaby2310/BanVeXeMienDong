@model BanVeXeMienDong.Models.Ticket
@{ ViewData["Title"] = "Sửa Giá Vé"; }

<div class="max-w-md mx-auto px-4 py-8">
    <a href="/Admin/Tickets" class="text-sm text-gray-500 hover:text-blue-600 font-medium mb-4 inline-block">
        <i class="bi bi-arrow-left me-1"></i> Quay lại
    </a>

    <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6">
        <h1 class="text-xl font-bold text-gray-900 mb-2">Sửa Giá Vé #@Model.Id</h1>
        <p class="text-sm text-gray-500 mb-5">@Model.DiemDi → @Model.DiemDen</p>


        @if (TempData["Error"] != null)
        {
            <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-xl text-sm mb-4">@TempData["Error"]</div>
        }

        <div class="bg-gray-50 rounded-xl p-4 mb-5 space-y-2 text-sm">
            <div class="flex justify-between"><span class="text-gray-500">Tuyến</span><span class="font-medium">@Model.DiemDi → @Model.DiemDen</span></div>
            <div class="flex justify-between"><span class="text-gray-500">Ngày đi</span><span class="font-medium">@Model.NgayDi.ToString("dd/MM/yyyy HH:mm")</span></div>
            <div class="flex justify-between"><span class="text-gray-500">Ghế</span><span class="font-medium">@Model.SoGhe</span></div>
            <div class="flex justify-between"><span class="text-gray-500">Hạng xe</span><span class="font-bold">@Model.HangXe</span></div>
            <div class="flex justify-between"><span class="text-gray-500">Giá hiện tại</span><span class="font-bold text-blue-600">@Model.GiaVe.ToString("N0")đ</span></div>
        </div>

        <form method="post" asp-action="EditTicketPrice" asp-controller="Admin" asp-route-id="@Model.Id">
            @Html.AntiForgeryToken()
            <div class="mb-5">
                <label class="block text-xs font-semibold text-gray-500 uppercase mb-2">Giá vé mới (VND)</label>
                <input type="number" name="giaVe" value="@Model.GiaVe" min="1000" step="1000"
                    class="w-full px-4 py-3 border-2 border-gray-200 rounded-xl text-lg font-bold text-blue-600 focus:border-blue-500 focus:ring-4 focus:ring-blue-100 transition-all">
            </div>
            <button type="submit" class="w-full py-3 bg-green-600 hover:bg-green-700 text-white font-semibold rounded-xl transition-all">
                <i class="bi bi-check-lg me-1"></i> Cập Nhật Giá
            </button>
        </form>
    </div>
</div>
