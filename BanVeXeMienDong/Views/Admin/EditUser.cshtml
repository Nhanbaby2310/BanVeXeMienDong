@model BanVeXeMienDong.Models.User
@{ ViewData["Title"] = "Chỉnh sửa User"; }

<div class="max-w-md mx-auto px-4 py-8">
    <a href="/Admin/Users" class="text-sm text-gray-500 hover:text-blue-600 font-medium mb-4 inline-block"><i class="bi bi-arrow-left me-1"></i> Quay lại</a>

    <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6">
        <h1 class="text-xl font-bold text-gray-900 mb-5">Chỉnh sửa User #@Model.Id</h1>

        @if (TempData["Error"] != null)
        {
            <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-xl text-sm mb-4">@TempData["Error"]</div>
        }

        <form method="post">
            @Html.AntiForgeryToken()

            <div class="mb-4">
                <label class="block text-xs font-semibold text-gray-500 uppercase mb-1">Username</label>
                <input type="text" name="username" value="@Model.Username"
                    class="w-full px-4 py-2.5 border-2 border-gray-200 rounded-xl text-sm focus:border-blue-500 focus:ring-4 focus:ring-blue-100 transition-all">
            </div>

            <div class="mb-6">
                <label class="block text-xs font-semibold text-gray-500 uppercase mb-1">Role</label>
                <select name="role" class="w-full px-4 py-2.5 border-2 border-gray-200 rounded-xl text-sm focus:border-blue-500 focus:ring-4 focus:ring-blue-100 transition-all">
                    <option value="Admin" selected="@(Model.Role == "Admin")">Admin</option>
                    <option value="User" selected="@(Model.Role == "User")">User</option>
                </select>
            </div>

            <button type="submit" class="w-full py-3 bg-blue-600 hover:bg-blue-700 text-white font-semibold rounded-xl transition-all">
                <i class="bi bi-check-lg me-1"></i> Lưu Thay Đổi
            </button>
        </form>
    </div>
</div>
