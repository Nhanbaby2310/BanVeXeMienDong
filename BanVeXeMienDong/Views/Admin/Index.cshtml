@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="flex items-center justify-between mb-8">
        <h1 class="text-2xl font-bold text-gray-900"><i class="bi bi-speedometer2 text-blue-600"></i> Dashboard</h1>
        <span class="px-3 py-1.5 bg-red-100 text-red-700 rounded-full text-xs font-bold">ADMIN</span>
    </div>

    @if (TempData["Success"] != null) { <div data-toast-success="@TempData["Success"]"></div> }
    @if (TempData["Error"] != null) { <div data-toast-error="@TempData["Error"]"></div> }

    <!-- Stats Grid -->
    <div class="grid grid-cols-2 lg:grid-cols-5 gap-4 mb-8">
        <div class="bg-white rounded-xl border border-gray-100 shadow-sm p-5 hover-lift">
            <div class="flex items-center gap-3">
                <div class="w-11 h-11 rounded-xl bg-blue-100 flex items-center justify-center">
                    <i class="bi bi-people text-xl text-blue-600"></i>
                </div>
                <div>
                    <div class="text-2xl font-black text-gray-900">@ViewBag.TotalUsers</div>
                    <div class="text-xs text-gray-400 font-medium">Người dùng</div>
                </div>
            </div>
        </div>

        <div class="bg-white rounded-xl border border-gray-100 shadow-sm p-5 hover-lift">
            <div class="flex items-center gap-3">
                <div class="w-11 h-11 rounded-xl bg-red-100 flex items-center justify-center">
                    <i class="bi bi-shield-check text-xl text-red-600"></i>
                </div>
                <div>
                    <div class="text-2xl font-black text-gray-900">@ViewBag.AdminCount</div>
                    <div class="text-xs text-gray-400 font-medium">Admin</div>
                </div>
            </div>
        </div>

        <div class="bg-white rounded-xl border border-gray-100 shadow-sm p-5 hover-lift">
            <div class="flex items-center gap-3">
                <div class="w-11 h-11 rounded-xl bg-green-100 flex items-center justify-center">
                    <i class="bi bi-person-check text-xl text-green-600"></i>
                </div>
                <div>
                    <div class="text-2xl font-black text-gray-900">@ViewBag.UserCount</div>
                    <div class="text-xs text-gray-400 font-medium">User</div>
                </div>
            </div>
        </div>

        <div class="bg-white rounded-xl border border-gray-100 shadow-sm p-5 hover-lift">
            <div class="flex items-center gap-3">
                <div class="w-11 h-11 rounded-xl bg-amber-100 flex items-center justify-center">
                    <i class="bi bi-ticket-perforated text-xl text-amber-600"></i>
                </div>
                <div>
                    <div class="text-2xl font-black text-gray-900">@ViewBag.TotalTickets</div>
                    <div class="text-xs text-gray-400 font-medium">Vé bán</div>
                </div>
            </div>
        </div>

        <div class="bg-white rounded-xl border border-gray-100 shadow-sm p-5 hover-lift">
            <div class="flex items-center gap-3">
                <div class="w-11 h-11 rounded-xl bg-purple-100 flex items-center justify-center">
                    <i class="bi bi-cash-coin text-xl text-purple-600"></i>
                </div>
                <div>
                    @{ decimal rev = ViewBag.TotalRevenue ?? 0m; }
                    <div class="text-xl font-black text-gray-900">@((rev / 1000000).ToString("F1"))M</div>
                    <div class="text-xs text-gray-400 font-medium">Doanh thu</div>
                </div>
            </div>
        </div>
    </div>

    <!-- Quick Actions -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        <a href="/Admin/Users" class="group bg-gradient-to-br from-blue-600 to-blue-800 rounded-2xl p-6 text-white hover-lift">
            <i class="bi bi-people text-3xl opacity-80"></i>
            <h3 class="font-bold text-lg mt-3">Quản Lý Người Dùng</h3>
            <p class="text-blue-200 text-sm mt-1">Xem, sửa, xóa tài khoản</p>
            <i class="bi bi-arrow-right mt-3 inline-block group-hover:translate-x-1 transition-transform"></i>
        </a>

        <a href="/Admin/Tickets" class="group bg-gradient-to-br from-green-600 to-green-800 rounded-2xl p-6 text-white hover-lift">
            <i class="bi bi-ticket-detailed text-3xl opacity-80"></i>
            <h3 class="font-bold text-lg mt-3">Quản Lý Vé Xe</h3>
            <p class="text-green-200 text-sm mt-1">Xem, sửa giá, xóa vé</p>
            <i class="bi bi-arrow-right mt-3 inline-block group-hover:translate-x-1 transition-transform"></i>
        </a>

        <a href="/Admin/Orders" class="group bg-gradient-to-br from-purple-600 to-purple-800 rounded-2xl p-6 text-white hover-lift">
            <i class="bi bi-receipt text-3xl opacity-80"></i>
            <h3 class="font-bold text-lg mt-3">Quản Lý Đơn Hàng</h3>
            <p class="text-purple-200 text-sm mt-1">Xác nhận, hủy đơn hàng</p>
            <i class="bi bi-arrow-right mt-3 inline-block group-hover:translate-x-1 transition-transform"></i>
        </a>
    </div>
</div>
