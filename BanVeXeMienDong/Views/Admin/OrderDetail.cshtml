@model BanVeXeMienDong.Models.Order
@{ ViewData["Title"] = "Chi Tiết Đơn Hàng - Admin"; }

<div class="max-w-3xl mx-auto px-4 py-8">
    <div class="flex items-center justify-between mb-6">
        <a href="/Admin/Orders" class="text-sm text-gray-500 hover:text-blue-600 font-medium">
            <i class="bi bi-arrow-left me-1"></i> Quay lại
        </a>
        @{
            var sc = Model.Status switch { "Confirmed" => "bg-green-100 text-green-700", "Cancelled" => "bg-red-100 text-red-700", _ => "bg-yellow-100 text-yellow-700" };
        }
        <span class="px-3 py-1.5 rounded-full text-xs font-bold @sc">@Model.Status</span>
    </div>

    <h1 class="text-xl font-bold text-gray-900 mb-6">Đơn #@Model.OrderCode</h1>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-6">
        <div class="bg-white rounded-xl border border-gray-100 shadow-sm p-5">
            <h3 class="text-xs font-bold text-gray-400 uppercase mb-3">Thông tin</h3>
            <div class="space-y-2 text-sm">
                <div class="flex justify-between"><span class="text-gray-500">Ngày đặt</span><span class="font-medium">@Model.OrderDate.ToString("dd/MM/yyyy HH:mm")</span></div>
                <div class="flex justify-between"><span class="text-gray-500">Khách hàng</span><span class="font-medium">@ViewBag.Username</span></div>
                <div class="flex justify-between"><span class="text-gray-500">SĐT</span><span class="font-medium">@Model.PhoneNumber</span></div>
                <div class="flex justify-between"><span class="text-gray-500">Email</span><span class="font-medium">@Model.Email</span></div>
                <div class="flex justify-between"><span class="text-gray-500">Thanh toán</span><span class="font-medium">@Model.PaymentMethod</span></div>
            </div>
        </div>

        <div class="bg-white rounded-xl border border-gray-100 shadow-sm p-5">
            <h3 class="text-xs font-bold text-gray-400 uppercase mb-3">Cập nhật trạng thái</h3>
            <form method="post" action="/Admin/UpdateOrderStatus" class="space-y-3">
                <input type="hidden" name="id" value="@Model.Id" />
                <select name="newStatus" class="w-full px-4 py-2.5 border-2 border-gray-200 rounded-xl text-sm">
                    <option value="Pending" selected="@(Model.Status == "Pending")">Chờ Xử Lý</option>
                    <option value="Confirmed" selected="@(Model.Status == "Confirmed")">Đã Xác Nhận</option>
                    <option value="Cancelled" selected="@(Model.Status == "Cancelled")">Đã Hủy</option>
                </select>
                <button type="submit" class="w-full py-2.5 bg-blue-600 hover:bg-blue-700 text-white font-semibold rounded-xl text-sm transition-all">
                    Cập Nhật
                </button>
            </form>

            <div class="mt-4 pt-4 border-t border-gray-100">
                <div class="flex justify-between items-center">
                    <span class="text-sm text-gray-500">Tổng tiền</span>
                    <span class="text-xl font-black text-blue-600">@Model.TotalAmount.ToString("N0")đ</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Items -->
    @if (ViewBag.Items != null)
    {
        <div class="bg-white rounded-xl border border-gray-100 shadow-sm p-5">
            <h3 class="text-xs font-bold text-gray-400 uppercase mb-3">Chi tiết vé</h3>
            <div class="space-y-2">
                @foreach (var item in ViewBag.Items)
                {
                    <div class="flex items-center gap-3 p-3 bg-gray-50 rounded-xl text-sm">
                        <div class="w-9 h-9 rounded-lg bg-blue-100 flex items-center justify-center flex-shrink-0">
                            <i class="bi bi-bus-front text-blue-600"></i>
                        </div>
                        <div class="flex-1">
                            <div class="font-semibold">@item.Route</div>
                            <div class="text-xs text-gray-400">@item.Seats | @item.BusClass | @item.DepartureTime</div>
                        </div>
                        <div class="font-bold text-blue-600">@item.Price.ToString("N0")đ</div>
                    </div>
                }
            </div>
        </div>
    }
</div>
