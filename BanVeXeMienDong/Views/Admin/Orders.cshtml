@model List<BanVeXeMienDong.Models.Order>
@{ ViewData["Title"] = "Quản Lý Đơn Hàng"; }

<div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="flex items-center justify-between mb-6">
        <h1 class="text-2xl font-bold text-gray-900"><i class="bi bi-receipt text-blue-600"></i> Đơn Hàng</h1>
        <a href="/Admin/Index" class="text-sm text-gray-500 hover:text-blue-600 font-medium"><i class="bi bi-arrow-left me-1"></i> Dashboard</a>
    </div>

    @if (TempData["Success"] != null) { <div data-toast-success="@TempData["Success"]"></div> }
    @if (TempData["Error"] != null) { <div data-toast-error="@TempData["Error"]"></div> }

    <!-- Stats -->
    <div class="grid grid-cols-2 sm:grid-cols-5 gap-3 mb-6">
        <div class="bg-white rounded-xl border border-gray-100 p-4 text-center">
            <div class="text-xl font-black text-gray-900">@ViewBag.TotalOrders</div>
            <div class="text-xs text-gray-400">Tổng</div>
        </div>
        <div class="bg-white rounded-xl border border-green-100 p-4 text-center">
            <div class="text-xl font-black text-green-600">@ViewBag.ConfirmedCount</div>
            <div class="text-xs text-gray-400">Xác nhận</div>
        </div>
        <div class="bg-white rounded-xl border border-yellow-100 p-4 text-center">
            <div class="text-xl font-black text-yellow-600">@ViewBag.PendingCount</div>
            <div class="text-xs text-gray-400">Chờ</div>
        </div>
        <div class="bg-white rounded-xl border border-red-100 p-4 text-center">
            <div class="text-xl font-black text-red-600">@ViewBag.CancelledCount</div>
            <div class="text-xs text-gray-400">Hủy</div>
        </div>
        <div class="bg-white rounded-xl border border-blue-100 p-4 text-center">
            <div class="text-lg font-black text-blue-600">@(((decimal)ViewBag.TotalRevenue).ToString("N0"))đ</div>
            <div class="text-xs text-gray-400">Doanh thu</div>
        </div>
    </div>

    <!-- Filter Tabs -->
    <div class="flex gap-2 mb-5 flex-wrap">
        <a href="/Admin/Orders" class="px-4 py-2 rounded-lg text-sm font-medium transition-all @(string.IsNullOrEmpty(ViewBag.CurrentFilter) ? "bg-blue-600 text-white" : "bg-gray-100 text-gray-600 hover:bg-gray-200")">Tất cả</a>
        <a href="/Admin/Orders?status=Confirmed" class="px-4 py-2 rounded-lg text-sm font-medium transition-all @(ViewBag.CurrentFilter == "Confirmed" ? "bg-green-600 text-white" : "bg-gray-100 text-gray-600 hover:bg-gray-200")">Đã xác nhận</a>
        <a href="/Admin/Orders?status=Pending" class="px-4 py-2 rounded-lg text-sm font-medium transition-all @(ViewBag.CurrentFilter == "Pending" ? "bg-yellow-500 text-white" : "bg-gray-100 text-gray-600 hover:bg-gray-200")">Chờ xử lý</a>
        <a href="/Admin/Orders?status=Cancelled" class="px-4 py-2 rounded-lg text-sm font-medium transition-all @(ViewBag.CurrentFilter == "Cancelled" ? "bg-red-600 text-white" : "bg-gray-100 text-gray-600 hover:bg-gray-200")">Đã hủy</a>
    </div>

    <!-- Orders List -->
    @if (Model.Count == 0)
    {
        <div class="text-center py-16 bg-white rounded-2xl border border-gray-100">
            <i class="bi bi-inbox text-5xl text-gray-300"></i>
            <p class="text-gray-500 mt-3">Không có đơn hàng nào</p>
        </div>
    }
    else
    {
        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-x-auto">
            <table class="w-full text-sm">
                <thead class="bg-gray-50 border-b border-gray-100">
                    <tr>
                        <th class="px-4 py-3 text-left text-xs font-bold text-gray-500 uppercase">Mã đơn</th>
                        <th class="px-4 py-3 text-left text-xs font-bold text-gray-500 uppercase">Ngày</th>
                        <th class="px-4 py-3 text-left text-xs font-bold text-gray-500 uppercase">Email</th>
                        <th class="px-4 py-3 text-right text-xs font-bold text-gray-500 uppercase">Tổng tiền</th>
                        <th class="px-4 py-3 text-center text-xs font-bold text-gray-500 uppercase">Trạng thái</th>
                        <th class="px-4 py-3 text-right text-xs font-bold text-gray-500 uppercase">Hành động</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-50">
                    @foreach (var order in Model)
                    {
                        var sc = order.Status switch { "Confirmed" => "bg-green-100 text-green-700", "Cancelled" => "bg-red-100 text-red-700", _ => "bg-yellow-100 text-yellow-700" };

                        <tr class="hover:bg-gray-50 transition-colors">
                            <td class="px-4 py-3 font-semibold text-gray-900">@order.OrderCode</td>
                            <td class="px-4 py-3 text-gray-500">@order.OrderDate.ToString("dd/MM HH:mm")</td>
                            <td class="px-4 py-3 text-gray-500">@order.Email</td>
                            <td class="px-4 py-3 text-right font-bold text-blue-600">@order.TotalAmount.ToString("N0")đ</td>
                            <td class="px-4 py-3 text-center">
                                <span class="px-2.5 py-1 rounded-full text-xs font-bold @sc">@order.Status</span>
                            </td>
                            <td class="px-4 py-3">
                                <div class="flex items-center justify-end gap-1.5">
                                    <a href="/Admin/OrderDetail/@order.Id" class="w-7 h-7 rounded-md bg-blue-50 hover:bg-blue-100 text-blue-600 flex items-center justify-center text-xs" title="Xem">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    @if (order.Status == "Pending")
                                    {
                                        <form method="post" action="/Admin/UpdateOrderStatus" class="inline">
                                            <input type="hidden" name="id" value="@order.Id" />
                                            <input type="hidden" name="newStatus" value="Confirmed" />
                                            <button type="submit" class="w-7 h-7 rounded-md bg-green-50 hover:bg-green-100 text-green-600 flex items-center justify-center text-xs" title="Xác nhận">
                                                <i class="bi bi-check-lg"></i>
                                            </button>
                                        </form>
                                    }
                                    @if (order.Status != "Cancelled")
                                    {
                                        <form method="post" action="/Admin/UpdateOrderStatus" class="inline" onsubmit="return confirm('Hủy đơn này?')">
                                            <input type="hidden" name="id" value="@order.Id" />
                                            <input type="hidden" name="newStatus" value="Cancelled" />
                                            <button type="submit" class="w-7 h-7 rounded-md bg-red-50 hover:bg-red-100 text-red-600 flex items-center justify-center text-xs" title="Hủy">
                                                <i class="bi bi-x-lg"></i>
                                            </button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
