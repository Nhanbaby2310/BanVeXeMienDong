    /* Responsive Design */
    @@media (max-width: 1024px) {
        .search-form {
            grid-template-columns: repeat(2, 1fr);
        }

        .hero-title {
            font-size: 36px;
        }

        .tickets-grid {
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
        }
    }

    @@media (max-width: 768px) {
        .hero-banner {
            padding: 40px 20px 30px 20px;
            min-height: auto;
        }

        .hero-title {
            font-size: 28px;
            gap: 10px;
        }

        .hero-title i {
            font-size: 36px;
        }

        .hero-subtitle {
            font-size: 16px;
        }

        .search-form {
            grid-template-columns: 1fr;
            padding: 15px;
        }

        .search-btn {
            width: 100%;
        }

        .filter-tabs {
            justify-content: flex-start;
            overflow-x: auto;
            padding-bottom: 10px;
        }

        .promo-section {
            grid-template-columns: repeat(2, 1fr);
            gap: 12px;
        }

        .stats-grid {
            grid-template-columns: 1fr;
        }

        .stat-card {
            padding: 20px;
        }

        .tickets-section {
            margin: 0 15px 30px 15px;
