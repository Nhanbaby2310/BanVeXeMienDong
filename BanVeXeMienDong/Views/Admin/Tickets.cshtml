        .ticket-info-row {
            flex-direction: column;
            gap: 6px;
        }

        .ticket-info-row .value {
            text-align: left;
        }
    }
</style>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        console.log('🎫 Ticket management initialized');

        const filterButtons = document.querySelectorAll('.filter-tab');
        const searchBtn = document.getElementById('searchBtn');
        const ticketsGrid = document.querySelector('.tickets-grid');

        // Helper function to get all visible cards
        function getVisibleCards() {
            if (!ticketsGrid) return [];
            return Array.from(ticketsGrid.querySelectorAll('.ticket-card')).filter(card => card.style.display !== 'none');
        }

        // Helper function to extract date from ticket card
        function extractDate(card) {
            const dateElements = card.querySelectorAll('.ticket-info-row .value');
            if (dateElements.length >= 3) {
                const dateText = dateElements[2].textContent.trim(); // 3rd value is date
                const parts = dateText.match(/(\d+)\/(\d+)\/(\d+)/);
                if (parts) {
                    return new Date(parts[3], parts[2] - 1, parts[1]);
                }
            }
            return null;
        }

        // Helper function to extract price from ticket card
        function extractPrice(card) {
            const priceElement = card.querySelector('.price');
            if (priceElement) {
                const priceText = priceElement.textContent;
                const price = parseInt(priceText.replace(/\D/g, ''));
                return isNaN(price) ? 0 : price;
            }
            return 0;
        }

        // 1. FILTER BY DATE RANGE (Hôm Nay, Tuần Này, Tháng Này)
        filterButtons.forEach(button => {
            button.addEventListener('click', function () {
                filterButtons.forEach(btn => btn.classList.remove('active'));
                this.classList.add('active');

                const filterType = this.getAttribute('data-filter');
                const now = new Date();
                const todayStart = new Date(now.getFullYear(), now.getMonth(), now.getDate());
                const todayEnd = new Date(now.getFullYear(), now.getMonth(), now.getDate() + 1);

                let weekStart = new Date(todayStart);
                weekStart.setDate(weekStart.getDate() - weekStart.getDay());
                let weekEnd = new Date(weekStart);
                weekEnd.setDate(weekEnd.getDate() + 7);

                let monthStart = new Date(now.getFullYear(), now.getMonth(), 1);
                let monthEnd = new Date(now.getFullYear(), now.getMonth() + 1, 0);

                if (ticketsGrid) {
                    const cards = ticketsGrid.querySelectorAll('.ticket-card');
                    cards.forEach(card => {
                        const ticketDate = extractDate(card);
                        let show = true;

                        if (filterType !== 'all' && ticketDate) {
                            if (filterType === 'today') {
                                show = ticketDate >= todayStart && ticketDate < todayEnd;
                            } else if (filterType === 'week') {
                                show = ticketDate >= weekStart && ticketDate < weekEnd;
                            } else if (filterType === 'month') {
                                show = ticketDate >= monthStart && ticketDate <= monthEnd;
                            }
                        }

                        card.style.display = show ? 'block' : 'none';
                    });
                }
            });
        });

        // 2. SEARCH FUNCTIONALITY
        if (searchBtn) {
            searchBtn.addEventListener('click', performSearch);

            // Allow Enter key to search
            ['searchFrom', 'searchTo', 'searchDate', 'searchCustomer'].forEach(id => {
                const elem = document.getElementById(id);
                if (elem) {
                    elem.addEventListener('keypress', function (e) {
                        if (e.key === 'Enter') performSearch();
                    });
                }
            });
        }

        function performSearch() {
            const from = document.getElementById('searchFrom')?.value.toLowerCase().trim() || '';
            const to = document.getElementById('searchTo')?.value.toLowerCase().trim() || '';
            const date = document.getElementById('searchDate')?.value || '';
            const customer = document.getElementById('searchCustomer')?.value.toLowerCase().trim() || '';

            if (ticketsGrid) {
                const cards = ticketsGrid.querySelectorAll('.ticket-card');
                cards.forEach(card => {
                    let show = true;

                    // Filter by departure point (flexible matching)
                    if (from) {
                        const fromElement = card.querySelector('.route-badge .from');
                        const fromText = fromElement?.textContent.toLowerCase().trim() || '';
                        // Match with substring, handles variations like HCM, Sài Gòn, etc.
                        show = show && (fromText.includes(from) || from.includes(fromText));
                    }

                    // Filter by destination point (flexible matching)
                    if (to) {
                        const toElement = card.querySelector('.route-badge .to');
                        const toText = toElement?.textContent.toLowerCase().trim() || '';
                        // Match with substring, handles variations
                        show = show && (toText.includes(to) || to.includes(toText));
                    }

                    // Filter by customer (first .value is customer name)
                    if (customer) {
                        const values = card.querySelectorAll('.ticket-info-row .value');
                        const customerText = values[0]?.textContent.toLowerCase() || '';
                        show = show && customerText.includes(customer);
                    }

                    // Filter by date
                    if (date) {
                        const ticketDate = extractDate(card);
                        if (ticketDate) {
                            const selectedDate = new Date(date);
                            show = show && ticketDate.toDateString() === selectedDate.toDateString();
                        } else {
                            show = false;
                        }
                    }

                    card.style.display = show ? 'block' : 'none';
                });
            }
        }

        // 3. SORT FUNCTIONALITY
        const sortSelect = document.getElementById('sortOptions');
        if (sortSelect) {
            sortSelect.addEventListener('change', function () {
                if (!ticketsGrid) return;

                const cards = getVisibleCards();
                const sortType = this.value;

                if (sortType === 'price-low') {
                    cards.sort((a, b) => extractPrice(a) - extractPrice(b));
                } else if (sortType === 'price-high') {
                    cards.sort((a, b) => extractPrice(b) - extractPrice(a));
                } else if (sortType === 'date-early') {
                    cards.sort((a, b) => {
                        const dateA = extractDate(a);
                        const dateB = extractDate(b);
                        return (dateA || new Date(0)) - (dateB || new Date(0));
                    });
                } else if (sortType === 'date-late') {
                    cards.sort((a, b) => {
                        const dateA = extractDate(a);
                        const dateB = extractDate(b);
                        return (dateB || new Date(0)) - (dateA || new Date(0));
                    });
                }

                // Reorder cards in grid
                cards.forEach(card => ticketsGrid.appendChild(card));
                console.log('✅ Sorted:', sortType);
            });
        }

        // 4. BUS TYPE FILTER
        const busTypeCheckboxes = document.querySelectorAll('input[name="busType"]');
        busTypeCheckboxes.forEach(checkbox => {
            checkbox.addEventListener('change', function () {
                const selectedTypes = Array.from(busTypeCheckboxes)
                    .filter(cb => cb.checked)
                    .map(cb => cb.value);

                if (ticketsGrid) {
                    const cards = ticketsGrid.querySelectorAll('.ticket-card');
                    cards.forEach(card => {
                        if (selectedTypes.length === 0) {
                            card.style.display = 'block';
                        } else {
                            const classBadge = card.querySelector('.class-badge');
                            const busClass = classBadge?.textContent.toLowerCase() || '';
                            const show = selectedTypes.some(type => {
                                return (type === 'standard' && busClass.includes('thường')) ||
                                       (type === 'vip' && busClass.includes('vip'));
                            });
                            card.style.display = show ? 'block' : 'none';
                        }
                    });
                }
                console.log('✅ Bus type filtered:', selectedTypes);
            });
        });

        // 5. PRICE RANGE FILTER
        const priceSlider = document.getElementById('priceRange');
        const priceDisplay = document.getElementById('priceDisplay');

        if (priceSlider) {
            priceSlider.addEventListener('input', function () {
                const maxPrice = parseInt(this.value);

                if (priceDisplay) {
                    priceDisplay.textContent = maxPrice.toLocaleString('vi-VN') + ' đ';
                }

                if (ticketsGrid) {
                    const cards = ticketsGrid.querySelectorAll('.ticket-card');
                    cards.forEach(card => {
                        const price = extractPrice(card);
                        card.style.display = price <= maxPrice ? 'block' : 'none';
                    });
                }
                console.log('✅ Price filtered: Max', maxPrice);
            });
        }

        console.log('✅ All ticket filters ready');
    });
</script>
