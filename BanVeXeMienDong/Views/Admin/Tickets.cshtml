@using BanVeXeMienDong.Models
@model List<BanVeXeMienDong.Models.Ticket>

@{
    ViewData["Title"] = "Quản Lý Vé Xe";
    var tickets = Model ?? new List<Ticket>();
}

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="flex items-center justify-between mb-6">
        <h1 class="text-2xl font-bold text-gray-900"><i class="bi bi-ticket-perforated text-blue-600"></i> Vé Xe</h1>
        <a href="/Admin/Index" class="text-sm text-gray-500 hover:text-blue-600 font-medium"><i class="bi bi-arrow-left me-1"></i> Dashboard</a>
    </div>

    @if (TempData["Success"] != null) { <div data-toast-success="@TempData["Success"]"></div> }
    @if (TempData["Error"] != null) { <div data-toast-error="@TempData["Error"]"></div> }

    <!-- Stats -->
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-6">
        <div class="bg-white rounded-xl border border-gray-100 p-4 text-center">
            <div class="text-2xl font-black text-gray-900">@tickets.Count</div>
            <div class="text-xs text-gray-400">Tổng vé</div>
        </div>
        <div class="bg-white rounded-xl border border-gray-100 p-4 text-center">
            <div class="text-lg font-black text-blue-600">@(tickets.Sum(t => t.GiaVe).ToString("N0"))đ</div>
            <div class="text-xs text-gray-400">Tổng doanh thu</div>
        </div>
        <div class="bg-white rounded-xl border border-gray-100 p-4 text-center">
            <div class="text-2xl font-black text-green-600">@tickets.Count(t => t.HangXe == BusClass.Standard)</div>
            <div class="text-xs text-gray-400">Xe Thường</div>
        </div>
        <div class="bg-white rounded-xl border border-gray-100 p-4 text-center">
            <div class="text-2xl font-black text-amber-600">@tickets.Count(t => t.HangXe == BusClass.Premium)</div>
            <div class="text-xs text-gray-400">Xe VIP</div>
        </div>
    </div>

    <!-- Tickets Grid -->
    @if (tickets.Count == 0)
    {
        <div class="text-center py-16 bg-white rounded-2xl border border-gray-100">
            <i class="bi bi-inbox text-5xl text-gray-300"></i>
            <p class="text-gray-500 mt-3">Chưa có vé nào</p>
        </div>
    }
    else
    {
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
            @foreach (var ticket in tickets.Take(30))
            {
                <div class="bg-white rounded-xl border border-gray-100 shadow-sm overflow-hidden hover:shadow-md transition-all">
                    <!-- Header -->
                    <div class="px-4 py-3 bg-gray-50 border-b border-gray-100 flex items-center justify-between">
                        <span class="text-xs font-bold text-gray-400">#@ticket.Id</span>
                        <span class="px-2 py-0.5 rounded text-xs font-bold @(ticket.HangXe == BusClass.Premium ? "bg-amber-100 text-amber-700" : "bg-blue-100 text-blue-700")">
                            @(ticket.HangXe == BusClass.Premium ? "VIP" : "Standard")
                        </span>
                    </div>

                    <!-- Body -->
                    <div class="p-4">
                        <div class="font-semibold text-gray-900 mb-2">@ticket.DiemDi → @ticket.DiemDen</div>
                        <div class="space-y-1.5 text-xs text-gray-500">
                            <div class="flex justify-between"><span>Ngày đi</span><span class="font-medium text-gray-700">@ticket.NgayDi.ToString("dd/MM/yyyy HH:mm")</span></div>
                            <div class="flex justify-between"><span>Ghế</span><span class="font-medium text-gray-700">@ticket.SoGhe</span></div>
                            <div class="flex justify-between"><span>Giá</span><span class="font-bold text-blue-600">@ticket.GiaVe.ToString("N0")đ</span></div>
                        </div>
                    </div>

                    <!-- Actions -->
                    <div class="px-4 py-3 bg-gray-50 border-t border-gray-100 flex items-center gap-2">
                        <a href="/Admin/EditTicketPrice/@ticket.Id" class="flex-1 py-1.5 bg-blue-50 hover:bg-blue-100 text-blue-700 text-xs font-semibold rounded-lg text-center transition-all">
                            <i class="bi bi-pencil"></i> Sửa giá
                        </a>
                        <form method="post" action="/Admin/DeleteTicket/@ticket.Id" class="flex-1" onsubmit="return confirm('Xóa vé này?')">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="w-full py-1.5 bg-red-50 hover:bg-red-100 text-red-700 text-xs font-semibold rounded-lg transition-all">
                                <i class="bi bi-trash3"></i> Xóa
                            </button>
                        </form>
                    </div>
                </div>
            }
        </div>
    }
</div>
