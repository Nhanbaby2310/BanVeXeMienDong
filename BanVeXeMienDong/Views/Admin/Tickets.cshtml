            padding: 20px 16px;
        }

        .stat-icon {
            width: 60px;
            height: 60px;
            font-size: 32px;
        }

        .stat-number {
            font-size: 24px;
        }

        .ticket-header {
            flex-direction: column;
            gap: 10px;
            align-items: flex-start;
        }

        .route-badge {
            width: 100%;
            flex-direction: column;
            gap: 8px;
        }

        .route-badge .from,
        .route-badge .to {
            width: 100%;
            text-align: center;
        }

        .ticket-id {
            width: 100%;
            text-align: left;
        }

        .search-form {
            padding: 12px;
            gap: 10px;
        }

        .badge-text {
            font-size: 12px;
        }

        .ticket-footer {
            flex-direction: column;
            gap: 8px;
        }

        .ticket-footer .btn {
            width: 100%;
