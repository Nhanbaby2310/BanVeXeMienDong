    @@media (max-width: 480px) {
        .hero-banner {
            padding: 30px 15px 20px 15px;
        }

        .hero-title {
            font-size: 22px;
            flex-direction: column;
        }

        .hero-subtitle {
            font-size: 14px;
        }

        .filter-tabs {
            flex-direction: column;
        }

        .filter-tab {
            width: 100%;
            justify-content: center;
        }

        .promo-section {
            grid-template-columns: 1fr;
            gap: 10px;
        }

        .stat-card {
            flex-direction: column;
