@model List<BanVeXeMienDong.Models.User>
@{ ViewData["Title"] = "Quản Lý Người Dùng"; }

<div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="flex items-center justify-between mb-6">
        <h1 class="text-2xl font-bold text-gray-900"><i class="bi bi-people text-blue-600"></i> Người Dùng</h1>
        <a href="/Admin/Index" class="text-sm text-gray-500 hover:text-blue-600 font-medium"><i class="bi bi-arrow-left me-1"></i> Dashboard</a>
    </div>

    @if (TempData["Success"] != null) { <div data-toast-success="@TempData["Success"]"></div> }
    @if (TempData["Error"] != null) { <div data-toast-error="@TempData["Error"]"></div> }

    <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
        <table class="w-full text-sm">
            <thead class="bg-gray-50 border-b border-gray-100">
                <tr>
                    <th class="px-5 py-3 text-left text-xs font-bold text-gray-500 uppercase">ID</th>
                    <th class="px-5 py-3 text-left text-xs font-bold text-gray-500 uppercase">Username</th>
                    <th class="px-5 py-3 text-left text-xs font-bold text-gray-500 uppercase">Role</th>
                    <th class="px-5 py-3 text-right text-xs font-bold text-gray-500 uppercase">Hành động</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-50">
                @foreach (var user in Model)
                {
                    <tr class="hover:bg-gray-50 transition-colors">
                        <td class="px-5 py-3">
                            <span class="inline-flex items-center justify-center w-8 h-8 rounded-lg bg-blue-50 text-blue-700 text-xs font-bold">@user.Id</span>
                        </td>
                        <td class="px-5 py-3">
                            <div class="flex items-center gap-2">
                                <i class="bi @(user.Role == "Admin" ? "bi-shield-check text-red-500" : "bi-person text-gray-400")"></i>
                                <span class="font-medium text-gray-900">@user.Username</span>
                            </div>
                        </td>
                        <td class="px-5 py-3">
                            <span class="px-2.5 py-1 rounded-full text-xs font-bold @(user.Role == "Admin" ? "bg-red-100 text-red-700" : "bg-blue-100 text-blue-700")">
                                @user.Role
                            </span>
                        </td>
                        <td class="px-5 py-3 text-right">
                            <div class="flex items-center justify-end gap-2">
                                <a href="/Admin/EditUser/@user.Id" class="w-8 h-8 rounded-lg bg-blue-50 hover:bg-blue-100 text-blue-600 flex items-center justify-center transition-all" title="Sửa">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                @if (user.Id != 1)
                                {
                                    <form method="post" action="/Admin/DeleteUser/@user.Id" onsubmit="return confirm('Xóa user này?')">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="w-8 h-8 rounded-lg bg-red-50 hover:bg-red-100 text-red-600 flex items-center justify-center transition-all" title="Xóa">
                                            <i class="bi bi-trash3"></i>
                                        </button>
                                    </form>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
