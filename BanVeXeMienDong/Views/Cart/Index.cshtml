@model List<BanVeXeMienDong.Models.CartItem>

@{
    ViewData["Title"] = "Giỏ Hàng";
    ViewBag.Breadcrumbs = new List<(string Title, string Url)>
    {
        ("Tìm vé", "/Ticket/SelectRoute"),
        ("Giỏ hàng", "/Cart/Index")
    };
}

<div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <h1 class="text-2xl font-bold text-gray-900 mb-6"><i class="bi bi-bag text-blue-600"></i> Giỏ Hàng</h1>

    @if (TempData["Success"] != null)
    {
        <div data-toast-success="@TempData["Success"]"></div>
    }
    @if (TempData["Error"] != null)
    {
        <div data-toast-error="@TempData["Error"]"></div>
    }

    @if (Model == null || Model.Count == 0)
    {
        <div class="text-center py-20 bg-white rounded-2xl shadow-sm border border-gray-100">
            <i class="bi bi-cart-x text-6xl text-gray-300"></i>
            <h3 class="text-lg font-semibold text-gray-700 mt-4">Giỏ hàng trống</h3>
            <p class="text-sm text-gray-400 mt-1">Hãy tìm chuyến xe và đặt vé ngay!</p>
            <a href="/Ticket/SelectRoute" class="inline-flex items-center gap-2 mt-6 px-6 py-3 bg-blue-600 hover:bg-blue-700 text-white font-semibold rounded-xl transition-all">
                <i class="bi bi-search"></i> Tìm chuyến xe
            </a>
        </div>
    }
    else
    {
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
            <!-- Cart Items -->
            <div class="lg:col-span-2 space-y-4">
                @foreach (var item in Model)
                {
                    <div class="bg-white rounded-xl border border-gray-100 shadow-sm p-5 hover:shadow-md transition-all">
                        <div class="flex flex-col sm:flex-row sm:items-center gap-4">
                            <!-- Icon -->
                            <div class="w-12 h-12 rounded-xl bg-blue-100 flex items-center justify-center flex-shrink-0">
                                <i class="bi bi-bus-front text-blue-600 text-xl"></i>
                            </div>

                            <!-- Info -->
                            <div class="flex-1">
                                <h3 class="font-semibold text-gray-900">@item.Route</h3>
                                <div class="flex flex-wrap gap-2 mt-1.5">
                                    <span class="px-2 py-0.5 bg-gray-100 text-gray-600 rounded text-xs">@item.BusClass</span>
                                    <span class="px-2 py-0.5 bg-gray-100 text-gray-600 rounded text-xs"><i class="bi bi-clock"></i> @item.DepartureTime</span>
                                    <span class="px-2 py-0.5 bg-blue-50 text-blue-700 rounded text-xs font-medium">Ghế: @item.Seats</span>
                                </div>
                            </div>

                            <!-- Price -->
                            <div class="text-right">
                                <div class="text-lg font-bold text-blue-600">@item.Price.ToString("N0")đ</div>
                                <div class="text-xs text-gray-400">@item.Quantity ghế</div>
                            </div>

                            <!-- Remove -->
                            <form method="post" action="/Cart/RemoveFromCart" onsubmit="return confirm('Xóa vé này?')">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="itemId" value="@item.Id" />
                                <button type="submit" class="w-9 h-9 rounded-lg bg-red-50 hover:bg-red-100 text-red-500 flex items-center justify-center transition-all">
                                    <i class="bi bi-trash3"></i>
                                </button>
                            </form>
                        </div>
                    </div>
                }
            </div>

            <!-- Summary -->
            <div class="lg:col-span-1">
                <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6 sticky top-20">
                    <h3 class="font-bold text-gray-900 mb-4">Tóm Tắt Đơn Hàng</h3>

                    <div class="space-y-3 pb-4 border-b border-gray-100">
                        <div class="flex justify-between text-sm">
                            <span class="text-gray-500">Số vé:</span>
                            <span class="font-medium">@ViewBag.CartCount</span>
                        </div>
                    </div>

                    <div class="flex justify-between items-center pt-4 mb-6">
                        <span class="font-semibold text-gray-700">Tổng cộng:</span>
                        <span class="text-2xl font-black text-blue-600">@ViewBag.Total.ToString("N0")đ</span>
                    </div>

                    <div class="space-y-3">
                        <a href="/Checkout/Index" class="block w-full py-3 bg-gradient-to-r from-green-600 to-green-700 hover:from-green-700 hover:to-green-800 text-white font-semibold rounded-xl text-center shadow-sm hover:shadow-md transition-all">
                            <i class="bi bi-credit-card me-1"></i> Thanh Toán
                        </a>
                        <a href="/Ticket/SelectRoute" class="block w-full py-3 bg-gray-100 hover:bg-gray-200 text-gray-700 font-medium rounded-xl text-center transition-all text-sm">
                            <i class="bi bi-arrow-left me-1"></i> Tiếp tục mua
                        </a>
                        <form method="post" action="/Cart/ClearCart" onsubmit="return confirm('Xóa toàn bộ giỏ hàng?')">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="w-full py-2.5 text-red-600 hover:bg-red-50 font-medium rounded-xl text-center transition-all text-sm">
                                <i class="bi bi-trash3 me-1"></i> Xóa tất cả
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    }
</div>
