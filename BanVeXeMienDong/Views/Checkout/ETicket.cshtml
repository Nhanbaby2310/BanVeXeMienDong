@model BanVeXeMienDong.Models.Order
@{ ViewData["Title"] = "Vé Điện Tử"; }

<div class="max-w-2xl mx-auto px-4 py-8">
    <!-- Actions (hidden when printing) -->
    <div class="flex justify-between items-center mb-6 print:hidden">
        <a href="/Checkout/MyOrders" class="text-sm text-gray-500 hover:text-blue-600 font-medium">
            <i class="bi bi-arrow-left me-1"></i> Quay lại
        </a>
        <button onclick="window.print()" class="px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white text-sm font-semibold rounded-xl transition-all">
            <i class="bi bi-printer me-1"></i> In vé
        </button>
    </div>

    @if (ViewBag.Items != null)
    {
        var items = (List<BanVeXeMienDong.Models.CartItem>)ViewBag.Items;
        int ticketNum = 0;

        foreach (var item in items)
        {
            ticketNum++;
            var ticketId = $"{Model.OrderCode}-{ticketNum:D2}";
            var qrData = Uri.EscapeDataString($"TICKET:{ticketId}|ROUTE:{item.Route}|DATE:{item.DepartureTime}|SEATS:{item.Seats}");

            <div class="bg-white rounded-2xl border-2 border-gray-200 shadow-sm overflow-hidden mb-6 print:shadow-none print:border-gray-400">
                <div class="grid grid-cols-1 sm:grid-cols-3">
                    <!-- QR Section -->
                    <div class="sm:col-span-1 bg-gray-50 p-6 flex flex-col items-center justify-center border-b sm:border-b-0 sm:border-r-2 border-dashed border-gray-200">
                        <img src="https://api.qrserver.com/v1/create-qr-code/?size=150x150&data=@qrData"
                             alt="QR Code" class="w-36 h-36 rounded-lg shadow-sm">
                        <div class="mt-3 px-3 py-1 bg-white rounded-lg border border-gray-200 text-xs font-mono font-bold text-blue-700">
                            @ticketId
                        </div>
                    </div>

                    <!-- Info Section -->
                    <div class="sm:col-span-2 p-6">
                        <!-- Brand -->
                        <div class="flex items-center gap-2 mb-4">
                            <div class="w-8 h-8 rounded-lg gradient-primary flex items-center justify-center">
                                <i class="bi bi-bus-front text-white text-sm"></i>
                            </div>
                            <span class="text-sm font-bold text-gray-900">Bến Xe Miền Đông</span>
                        </div>

                        <!-- Route -->
                        <div class="gradient-primary text-white px-4 py-3 rounded-xl mb-4">
                            <div class="text-lg font-bold">@item.Route</div>
                        </div>

                        <!-- Details -->
                        <div class="grid grid-cols-2 gap-3 text-sm">
                            <div>
                                <div class="text-xs text-gray-400 uppercase">Khởi hành</div>
                                <div class="font-semibold text-gray-900">@item.DepartureTime</div>
                            </div>
                            <div>
                                <div class="text-xs text-gray-400 uppercase">Ghế</div>
                                <div class="font-bold text-red-600">@item.Seats</div>
                            </div>
                            <div>
                                <div class="text-xs text-gray-400 uppercase">Loại xe</div>
                                <div class="font-semibold text-gray-900">@item.BusClass</div>
                            </div>
                            <div>
                                <div class="text-xs text-gray-400 uppercase">Hành khách</div>
                                <div class="font-semibold text-gray-900">@ViewBag.Username</div>
                            </div>
                        </div>

                        <!-- Price & Status -->
                        <div class="flex items-center justify-between mt-4 pt-3 border-t border-gray-100">
                            <span class="text-xl font-black text-blue-600">@item.Price.ToString("N0")đ</span>
                            <span class="px-3 py-1 bg-green-100 text-green-700 rounded-full text-xs font-bold"><i class="bi bi-check-circle-fill me-1"></i>Đã xác nhận</span>
                        </div>
                    </div>
                </div>
            </div>
        }
    }

    <!-- Note -->
    <div class="bg-amber-50 border border-amber-200 rounded-xl p-4 print:border-amber-400">
        <h4 class="text-sm font-bold text-amber-800 mb-2"><i class="bi bi-info-circle me-1"></i> Lưu ý</h4>
        <ul class="text-xs text-amber-700 space-y-1">
            <li>• Xuất trình mã QR khi lên xe hoặc tại quầy vé</li>
            <li>• Có mặt tại bến xe trước giờ khởi hành 15 phút</li>
            <li>• Mã đơn hàng: <strong>@Model.OrderCode</strong></li>
            <li>• Hotline: <strong>1900 6067</strong></li>
        </ul>
    </div>
</div>

<style>
    @@media print {
        .print\:hidden { display: none !important; }
        .print\:shadow-none { box-shadow: none !important; }
        .print\:border-gray-400 { border-color: #9ca3af !important; }
        .print\:border-amber-400 { border-color: #fbbf24 !important; }
        nav, footer, .toast-container { display: none !important; }
        body { background: white !important; }
    }
</style>
