@model List<BanVeXeMienDong.Models.Order>

@{
    ViewData["Title"] = "Đơn Hàng Của Tôi";
    ViewBag.Breadcrumbs = new List<(string Title, string Url)>
    {
        ("Đơn hàng", "/Checkout/MyOrders")
    };
}

<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <h1 class="text-2xl font-bold text-gray-900 mb-6"><i class="bi bi-receipt text-blue-600"></i> Đơn Hàng Của Tôi</h1>

    @if (TempData["Success"] != null)
    {
        <div data-toast-success="@TempData["Success"]"></div>
    }

    @if (Model == null || Model.Count == 0)
    {
        <div class="text-center py-20 bg-white rounded-2xl shadow-sm border border-gray-100">
            <i class="bi bi-inbox text-6xl text-gray-300"></i>
            <h3 class="text-lg font-semibold text-gray-700 mt-4">Chưa có đơn hàng</h3>
            <p class="text-sm text-gray-400 mt-1">Đặt vé ngay để tạo đơn hàng đầu tiên!</p>
            <a href="/Ticket/SelectRoute" class="inline-flex items-center gap-2 mt-6 px-6 py-3 bg-blue-600 hover:bg-blue-700 text-white font-semibold rounded-xl transition-all">
                <i class="bi bi-ticket-perforated"></i> Đặt Vé Ngay
            </a>
        </div>
    }
    else
    {
        <div class="space-y-4">
            @foreach (var order in Model)
            {
                var statusColor = order.Status switch
                {
                    "Confirmed" => "bg-green-100 text-green-700",
                    "Cancelled" => "bg-red-100 text-red-700",
                    _ => "bg-yellow-100 text-yellow-700"
                };
                var statusIcon = order.Status switch
                {
                    "Confirmed" => "bi-check-circle-fill",
                    "Cancelled" => "bi-x-circle-fill",
                    _ => "bi-clock-fill"
                };

                <div class="bg-white rounded-xl border border-gray-100 shadow-sm overflow-hidden hover:shadow-md transition-all">
                    <!-- Header -->
                    <div class="flex items-center justify-between px-5 py-3 bg-gray-50 border-b border-gray-100">
                        <div class="flex items-center gap-3">
                            <span class="text-sm font-bold text-gray-900">@order.OrderCode</span>
                            <span class="text-xs text-gray-400">@order.OrderDate.ToString("dd/MM/yyyy HH:mm")</span>
                        </div>
                        <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-xs font-bold @statusColor">
                            <i class="bi @statusIcon"></i> @order.Status
                        </span>
                    </div>

                    <!-- Body -->
                    <div class="px-5 py-4">
                        <div class="flex flex-wrap items-center gap-4 text-sm">
                            <div>
                                <span class="text-gray-400 text-xs">Thanh toán</span>
                                <div class="font-medium text-gray-700">@order.PaymentMethod</div>
                            </div>
                            <div>
                                <span class="text-gray-400 text-xs">SĐT</span>
                                <div class="font-medium text-gray-700">@order.PhoneNumber</div>
                            </div>
                            <div class="ml-auto text-right">
                                <span class="text-gray-400 text-xs">Tổng tiền</span>
                                <div class="text-lg font-black text-blue-600">@order.TotalAmount.ToString("N0")đ</div>
                            </div>
                        </div>
                    </div>

                    <!-- Actions -->
                    <div class="flex items-center gap-2 px-5 py-3 bg-gray-50 border-t border-gray-100">
                        <a href="/Checkout/OrderDetail/@order.Id" class="px-3 py-1.5 bg-blue-100 hover:bg-blue-200 text-blue-700 text-xs font-semibold rounded-lg transition-all">
                            <i class="bi bi-eye me-1"></i> Chi tiết
                        </a>

                        @if (order.Status == "Confirmed")
                        {
                            <a href="/Checkout/ETicket/@order.Id" class="px-3 py-1.5 bg-green-100 hover:bg-green-200 text-green-700 text-xs font-semibold rounded-lg transition-all">
                                <i class="bi bi-qr-code me-1"></i> Vé điện tử
                            </a>

                            <form method="post" action="/Checkout/CancelOrder/@order.Id" class="ml-auto" onsubmit="return confirm('Bạn chắc chắn muốn hủy đơn hàng này?')">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="px-3 py-1.5 bg-red-100 hover:bg-red-200 text-red-700 text-xs font-semibold rounded-lg transition-all">
                                    <i class="bi bi-x-circle me-1"></i> Hủy đơn
                                </button>
                            </form>
                        }
                    </div>
                </div>
            }
        </div>
    }

    <!-- Back -->
    <div class="mt-8 text-center">
        <a href="/Ticket/SelectRoute" class="text-sm text-gray-500 hover:text-blue-600 font-medium">
            <i class="bi bi-arrow-left me-1"></i> Tiếp tục đặt vé
        </a>
    </div>
</div>
