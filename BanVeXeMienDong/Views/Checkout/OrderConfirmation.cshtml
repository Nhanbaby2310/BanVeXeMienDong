@model BanVeXeMienDong.Models.Order

@{
    ViewData["Title"] = "Đặt Vé Thành Công";
}

<div class="max-w-2xl mx-auto px-4 py-12 text-center">
    <!-- Success Icon -->
    <div class="w-20 h-20 mx-auto bg-green-100 rounded-full flex items-center justify-center mb-6">
        <i class="bi bi-check-lg text-4xl text-green-600"></i>
    </div>

    <h1 class="text-2xl font-bold text-gray-900 mb-2">Thanh Toán Thành Công!</h1>
    <p class="text-gray-500 mb-4">Cảm ơn bạn đã đặt vé. Đơn hàng của bạn đã được xác nhận.</p>

    <!-- Email Notification -->
    <div class="inline-flex items-center gap-2 px-4 py-2 bg-blue-50 border border-blue-200 rounded-xl text-sm text-blue-700 mb-8">
        <i class="bi bi-envelope-check"></i>
        <span>Email xác nhận đã được gửi đến <strong>@Model.Email</strong></span>
    </div>

    <!-- Order Details -->
    <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6 text-left mb-6">
        <h3 class="font-bold text-gray-900 mb-4"><i class="bi bi-receipt text-blue-600 me-2"></i>Chi Tiết Đơn Hàng</h3>

        <div class="space-y-3">
            <div class="flex justify-between py-2 border-b border-gray-50">
                <span class="text-sm text-gray-500">Mã đơn</span>
                <span class="text-sm font-bold text-gray-900">@Model.OrderCode</span>
            </div>
            <div class="flex justify-between py-2 border-b border-gray-50">
                <span class="text-sm text-gray-500">Ngày đặt</span>
                <span class="text-sm font-medium">@Model.OrderDate.ToString("dd/MM/yyyy HH:mm")</span>
            </div>
            <div class="flex justify-between py-2 border-b border-gray-50">
                <span class="text-sm text-gray-500">Thanh toán</span>
                <span class="text-sm font-medium">@Model.PaymentMethod</span>
            </div>
            <div class="flex justify-between py-2 border-b border-gray-50">
                <span class="text-sm text-gray-500">SĐT</span>
                <span class="text-sm font-medium">@Model.PhoneNumber</span>
            </div>
            <div class="flex justify-between py-2">
                <span class="text-sm font-semibold text-gray-700">Tổng cộng</span>
                <span class="text-lg font-black text-blue-600">@Model.TotalAmount.ToString("N0")đ</span>
            </div>
        </div>
    </div>

    <!-- Tickets -->
    @if (ViewBag.Items != null)
    {
        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6 text-left mb-6">
            <h3 class="font-bold text-gray-900 mb-4"><i class="bi bi-ticket-perforated text-blue-600 me-2"></i>Vé Đã Đặt</h3>
            <div class="space-y-3">
                @foreach (var item in ViewBag.Items)
                {
                    <div class="p-3 bg-gray-50 rounded-xl">
                        <div class="font-semibold text-sm text-gray-800">@item.Route</div>
                        <div class="text-xs text-gray-400 mt-1">Ghế: @item.Seats | @item.BusClass | @item.DepartureTime</div>
                        <div class="text-sm font-bold text-blue-600 mt-1">@item.Price.ToString("N0")đ</div>
                    </div>
                }
            </div>
        </div>
    }

    <!-- Next Steps -->
    <div class="bg-amber-50 border border-amber-200 rounded-2xl p-5 text-left mb-8">
        <h4 class="font-bold text-amber-800 text-sm mb-2"><i class="bi bi-info-circle me-1"></i> Bước tiếp theo</h4>
        <ul class="text-sm text-amber-700 space-y-1">
            <li>✅ Vé điện tử sẽ có sẵn ngay bây giờ</li>
            <li>✅ Xuất trình QR code khi lên xe</li>
            <li>✅ Có mặt trước giờ khởi hành 15 phút</li>
        </ul>
    </div>

    <!-- Actions -->
    <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href="/Checkout/ETicket/@Model.Id" class="px-6 py-3 bg-gradient-to-r from-blue-600 to-blue-700 hover:from-blue-700 hover:to-blue-800 text-white font-semibold rounded-xl shadow-md transition-all">
            <i class="bi bi-qr-code me-1"></i> Xem Vé Điện Tử
        </a>
        <a href="/Checkout/MyOrders" class="px-6 py-3 bg-gray-100 hover:bg-gray-200 text-gray-700 font-medium rounded-xl transition-all">
            <i class="bi bi-list-check me-1"></i> Đơn hàng của tôi
        </a>
        <a href="/Ticket/SelectRoute" class="px-6 py-3 bg-gray-100 hover:bg-gray-200 text-gray-700 font-medium rounded-xl transition-all">
            <i class="bi bi-arrow-left me-1"></i> Tiếp tục mua
        </a>
    </div>
</div>
