@model BanVeXeMienDong.Models.Order

@{
    ViewData["Title"] = "Chi Tiết Đơn Hàng";
    var statusColor = Model.Status switch
    {
        "Confirmed" => "bg-green-100 text-green-700",
        "Cancelled" => "bg-red-100 text-red-700",
        _ => "bg-yellow-100 text-yellow-700"
    };
}

<div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Header -->
    <div class="flex items-center justify-between mb-6">
        <a href="/Checkout/MyOrders" class="text-sm text-gray-500 hover:text-blue-600 font-medium">
            <i class="bi bi-arrow-left me-1"></i> Quay lại
        </a>
        <span class="px-3 py-1.5 rounded-full text-xs font-bold @statusColor">@Model.Status</span>
    </div>

    <h1 class="text-xl font-bold text-gray-900 mb-6">Đơn hàng #@Model.OrderCode</h1>

    <!-- Info Cards -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-6">
        <div class="bg-white rounded-xl border border-gray-100 shadow-sm p-5">
            <h3 class="text-xs font-bold text-gray-400 uppercase mb-3">Thông tin đơn hàng</h3>
            <div class="space-y-2 text-sm">
                <div class="flex justify-between"><span class="text-gray-500">Mã đơn</span><span class="font-medium">@Model.OrderCode</span></div>
                <div class="flex justify-between"><span class="text-gray-500">Ngày đặt</span><span class="font-medium">@Model.OrderDate.ToString("dd/MM/yyyy HH:mm")</span></div>
                <div class="flex justify-between"><span class="text-gray-500">Trạng thái</span><span class="font-bold @(Model.Status == "Confirmed" ? "text-green-600" : Model.Status == "Cancelled" ? "text-red-600" : "text-yellow-600")">@Model.Status</span></div>
            </div>
        </div>

        <div class="bg-white rounded-xl border border-gray-100 shadow-sm p-5">
            <h3 class="text-xs font-bold text-gray-400 uppercase mb-3">Thanh toán</h3>
            <div class="space-y-2 text-sm">
                <div class="flex justify-between"><span class="text-gray-500">Phương thức</span><span class="font-medium">@Model.PaymentMethod</span></div>
                <div class="flex justify-between"><span class="text-gray-500">SĐT</span><span class="font-medium">@Model.PhoneNumber</span></div>
                <div class="flex justify-between"><span class="text-gray-500">Email</span><span class="font-medium">@Model.Email</span></div>
            </div>
        </div>
    </div>

    <!-- Items -->
    <div class="bg-white rounded-xl border border-gray-100 shadow-sm p-5 mb-6">
        <h3 class="text-xs font-bold text-gray-400 uppercase mb-4">Vé đã đặt</h3>

        @{
            var items = ViewBag.Items as List<BanVeXeMienDong.Models.CartItem>;
            if (items != null && items.Count > 0)
            {
                <div class="space-y-3">
                    @foreach (var item in items)
                    {
                        <div class="flex items-center gap-4 p-3 bg-gray-50 rounded-xl">
                            <div class="w-10 h-10 rounded-lg bg-blue-100 flex items-center justify-center flex-shrink-0">
                                <i class="bi bi-bus-front text-blue-600"></i>
                            </div>
                            <div class="flex-1 min-w-0">
                                <div class="font-semibold text-sm text-gray-900 truncate">@item.Route</div>
                                <div class="text-xs text-gray-400">Ghế @item.Seats | @item.BusClass | @item.DepartureTime</div>
                            </div>
                            <div class="text-right flex-shrink-0">
                                <div class="font-bold text-blue-600">@item.Price.ToString("N0")đ</div>
                                <div class="text-xs text-gray-400">@item.Quantity ghế</div>
                            </div>
                        </div>
                    }
                </div>
            }
        }
    </div>

    <!-- Total -->
    <div class="bg-gradient-to-r from-blue-600 to-blue-800 rounded-xl p-5 text-white flex items-center justify-between mb-6">
        <span class="font-semibold">Tổng tiền</span>
        <span class="text-2xl font-black">@Model.TotalAmount.ToString("N0")đ</span>
    </div>

    <!-- Actions -->
    <div class="flex flex-wrap gap-3 justify-center">
        @if (Model.Status == "Confirmed")
        {
            <a href="/Checkout/ETicket/@Model.Id" class="px-5 py-2.5 bg-green-600 hover:bg-green-700 text-white font-semibold rounded-xl text-sm transition-all">
                <i class="bi bi-qr-code me-1"></i> Xem Vé Điện Tử
            </a>

            <form method="post" action="/Checkout/CancelOrder/@Model.Id" onsubmit="return confirm('Hủy đơn hàng này?')">
                @Html.AntiForgeryToken()
                <button type="submit" class="px-5 py-2.5 bg-red-600 hover:bg-red-700 text-white font-semibold rounded-xl text-sm transition-all">
                    <i class="bi bi-x-circle me-1"></i> Hủy Đơn
                </button>
            </form>
        }

        <a href="/Checkout/MyOrders" class="px-5 py-2.5 bg-gray-200 hover:bg-gray-300 text-gray-700 font-medium rounded-xl text-sm transition-all">
            <i class="bi bi-arrow-left me-1"></i> Quay lại
        </a>
    </div>
</div>
