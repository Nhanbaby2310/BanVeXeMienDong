@{
    ViewData["Title"] = "Về Chúng Tôi";
}

<div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <!-- Hero -->
    <div class="text-center mb-12">
        <div class="w-20 h-20 mx-auto rounded-2xl gradient-primary flex items-center justify-center mb-4">
            <i class="bi bi-bus-front text-3xl text-white"></i>
        </div>
        <h1 class="text-3xl font-bold text-gray-900">Về Bến Xe Miền Đông</h1>
        <p class="text-gray-500 mt-3 max-w-2xl mx-auto">Hệ thống đặt vé xe khách trực tuyến uy tín hàng đầu Việt Nam, phục vụ hàng triệu lượt khách mỗi năm.</p>
    </div>

    <!-- Story -->
    <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-8 mb-8">
        <h2 class="text-xl font-bold text-gray-900 mb-4"><i class="bi bi-book text-blue-600 me-2"></i>Câu Chuyện Của Chúng Tôi</h2>
        <div class="text-gray-600 space-y-4 text-sm leading-relaxed">
            <p>Bến Xe Miền Đông được thành lập với sứ mệnh mang đến trải nghiệm đặt vé xe khách thuận tiện, nhanh chóng và an toàn cho mọi hành khách trên khắp Việt Nam.</p>
            <p>Với hơn 2000 tuyến đường, 500+ nhà xe đối tác uy tín, chúng tôi cam kết cung cấp dịch vụ chất lượng cao với giá cả cạnh tranh nhất thị trường.</p>
            <p>Hệ thống thanh toán đa dạng (thẻ tín dụng, chuyển khoản, ví điện tử) cùng vé điện tử QR code giúp hành khách đặt vé mọi lúc mọi nơi chỉ trong vài phút.</p>
        </div>
    </div>

    <!-- Values -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5 mb-8">
        <div class="bg-white rounded-xl border border-gray-100 p-5 text-center hover-lift">
            <div class="w-12 h-12 mx-auto rounded-xl bg-blue-100 flex items-center justify-center mb-3">
                <i class="bi bi-shield-check text-xl text-blue-600"></i>
            </div>
            <h3 class="font-bold text-gray-900 text-sm">An Toàn</h3>
            <p class="text-xs text-gray-500 mt-1">Mọi nhà xe đều được kiểm duyệt nghiêm ngặt</p>
        </div>
        <div class="bg-white rounded-xl border border-gray-100 p-5 text-center hover-lift">
            <div class="w-12 h-12 mx-auto rounded-xl bg-green-100 flex items-center justify-center mb-3">
                <i class="bi bi-lightning text-xl text-green-600"></i>
            </div>
            <h3 class="font-bold text-gray-900 text-sm">Nhanh Chóng</h3>
            <p class="text-xs text-gray-500 mt-1">Đặt vé chỉ trong 2 phút, nhận vé ngay</p>
        </div>
        <div class="bg-white rounded-xl border border-gray-100 p-5 text-center hover-lift">
            <div class="w-12 h-12 mx-auto rounded-xl bg-amber-100 flex items-center justify-center mb-3">
                <i class="bi bi-heart text-xl text-amber-600"></i>
            </div>
            <h3 class="font-bold text-gray-900 text-sm">Tận Tâm</h3>
            <p class="text-xs text-gray-500 mt-1">Hỗ trợ 24/7, luôn lắng nghe khách hàng</p>
        </div>
        <div class="bg-white rounded-xl border border-gray-100 p-5 text-center hover-lift">
            <div class="w-12 h-12 mx-auto rounded-xl bg-purple-100 flex items-center justify-center mb-3">
                <i class="bi bi-graph-up-arrow text-xl text-purple-600"></i>
            </div>
            <h3 class="font-bold text-gray-900 text-sm">Đổi Mới</h3>
            <p class="text-xs text-gray-500 mt-1">Công nghệ hiện đại, cập nhật liên tục</p>
        </div>
    </div>

    <!-- Team -->
    <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-8 mb-8">
        <h2 class="text-xl font-bold text-gray-900 mb-6 text-center">Đội Ngũ Của Chúng Tôi</h2>
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-6">
            <div class="text-center">
                <div class="w-16 h-16 mx-auto rounded-full bg-gradient-to-br from-blue-400 to-blue-600 flex items-center justify-center mb-2">
                    <i class="bi bi-person text-2xl text-white"></i>
                </div>
                <div class="font-semibold text-sm text-gray-900">50+</div>
                <div class="text-xs text-gray-400">Nhân viên</div>
            </div>
            <div class="text-center">
                <div class="w-16 h-16 mx-auto rounded-full bg-gradient-to-br from-green-400 to-green-600 flex items-center justify-center mb-2">
                    <i class="bi bi-headset text-2xl text-white"></i>
                </div>
                <div class="font-semibold text-sm text-gray-900">24/7</div>
                <div class="text-xs text-gray-400">Hỗ trợ</div>
            </div>
            <div class="text-center">
                <div class="w-16 h-16 mx-auto rounded-full bg-gradient-to-br from-amber-400 to-amber-600 flex items-center justify-center mb-2">
                    <i class="bi bi-building text-2xl text-white"></i>
                </div>
                <div class="font-semibold text-sm text-gray-900">3</div>
                <div class="text-xs text-gray-400">Văn phòng</div>
            </div>
            <div class="text-center">
                <div class="w-16 h-16 mx-auto rounded-full bg-gradient-to-br from-red-400 to-red-600 flex items-center justify-center mb-2">
                    <i class="bi bi-trophy text-2xl text-white"></i>
                </div>
                <div class="font-semibold text-sm text-gray-900">5 năm</div>
                <div class="text-xs text-gray-400">Kinh nghiệm</div>
            </div>
        </div>
    </div>

    <!-- Contact -->
    <div class="bg-gradient-to-r from-blue-600 to-blue-800 rounded-2xl p-8 text-white text-center">
        <h2 class="text-xl font-bold mb-2">Liên Hệ Với Chúng Tôi</h2>
        <p class="text-blue-100 text-sm mb-4">Mọi thắc mắc xin liên hệ qua các kênh sau</p>
        <div class="flex flex-wrap justify-center gap-4">
            <div class="flex items-center gap-2 bg-white/10 px-4 py-2 rounded-lg">
                <i class="bi bi-telephone"></i> <span class="text-sm font-medium">1900 6067</span>
            </div>
            <div class="flex items-center gap-2 bg-white/10 px-4 py-2 rounded-lg">
                <i class="bi bi-envelope"></i> <span class="text-sm font-medium">hotro@benxemiendong.vn</span>
            </div>
            <div class="flex items-center gap-2 bg-white/10 px-4 py-2 rounded-lg">
                <i class="bi bi-geo-alt"></i> <span class="text-sm font-medium">292 Đinh Bộ Lĩnh, Q.Bình Thạnh</span>
            </div>
        </div>
    </div>
</div>
