@{
    ViewData["Title"] = "Trang chủ - Đặt Vé Xe Khách Online";
}

<!-- Hero Section -->
<div class="-mx-4 sm:-mx-6 lg:-mx-8">
    <div class="relative bg-gradient-to-br from-blue-900 via-blue-800 to-blue-700 overflow-hidden">
        <!-- Background Pattern -->
        <div class="absolute inset-0 opacity-10">
            <div class="absolute top-10 left-10 w-72 h-72 bg-white rounded-full blur-3xl"></div>
            <div class="absolute bottom-10 right-10 w-96 h-96 bg-blue-400 rounded-full blur-3xl"></div>
        </div>

        <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 lg:py-24">
            <!-- Flash Sale Banner -->
            <div class="text-center mb-8">
                <div class="inline-flex items-center gap-3 bg-white/10 backdrop-blur-sm px-6 py-3 rounded-full border border-white/20">
                    <span class="animate-pulse text-yellow-400 text-lg">⚡</span>
                    <span class="text-white font-semibold">FLASH SALE</span>
                    <span class="bg-yellow-400 text-yellow-900 px-3 py-1 rounded-full text-sm font-bold">Giảm đến 50%</span>
                </div>
            </div>

            <!-- Main Heading -->
            <h1 class="text-center text-3xl sm:text-4xl lg:text-5xl font-bold text-white mb-4">
                Đặt Vé Xe Khách <span class="text-yellow-400">Online</span>
            </h1>
            <p class="text-center text-blue-100 text-lg mb-10 max-w-2xl mx-auto">
                Hơn 2000 tuyến đường, 500+ nhà xe uy tín. Đặt vé nhanh chóng, an toàn, giá tốt nhất.
            </p>

            <!-- Search Box -->
            <div class="max-w-4xl mx-auto">
                <div class="bg-white rounded-2xl shadow-2xl p-6 lg:p-8">
                    <form method="GET" action="/Ticket/SelectRoute" id="searchForm">
                        <div class="grid grid-cols-1 md:grid-cols-12 gap-4 items-end">
                            <!-- Điểm đi -->
                            <div class="md:col-span-3 relative">
                                <label class="block text-sm font-semibold text-gray-700 mb-2">
                                    <i class="bi bi-geo-alt text-blue-600"></i> Nơi xuất phát
                                </label>
                                <input type="text" name="diemDi" id="searchFrom" 
                                    class="w-full px-4 py-3 border-2 border-gray-200 rounded-xl text-sm focus:border-blue-500 focus:ring-4 focus:ring-blue-100 transition-all"
                                    placeholder="VD: Sài Gòn" required autocomplete="off">
                                <div id="fromSuggestions" class="absolute top-full left-0 right-0 bg-white border border-gray-200 rounded-xl mt-1 shadow-lg z-50 hidden max-h-48 overflow-y-auto"></div>
                            </div>

                            <!-- Swap Button -->
                            <div class="md:col-span-1 flex justify-center">
                                <button type="button" id="swapBtn" class="w-10 h-10 rounded-full bg-blue-100 hover:bg-blue-200 flex items-center justify-center text-blue-600 transition-all hover:rotate-180 duration-300">
                                    <i class="bi bi-arrow-left-right"></i>
                                </button>
                            </div>

                            <!-- Điểm đến -->
                            <div class="md:col-span-3 relative">
                                <label class="block text-sm font-semibold text-gray-700 mb-2">
                                    <i class="bi bi-geo-alt-fill text-red-500"></i> Nơi đến
                                </label>
                                <input type="text" name="diemDen" id="searchTo"
                                    class="w-full px-4 py-3 border-2 border-gray-200 rounded-xl text-sm focus:border-blue-500 focus:ring-4 focus:ring-blue-100 transition-all"
                                    placeholder="VD: Đà Nẵng" required autocomplete="off">
                                <div id="toSuggestions" class="absolute top-full left-0 right-0 bg-white border border-gray-200 rounded-xl mt-1 shadow-lg z-50 hidden max-h-48 overflow-y-auto"></div>
                            </div>

                            <!-- Ngày đi -->
                            <div class="md:col-span-3">
                                <label class="block text-sm font-semibold text-gray-700 mb-2">
                                    <i class="bi bi-calendar-event text-green-600"></i> Ngày đi
                                </label>
                                <input type="date" name="ngayDi" id="searchDate"
                                    class="w-full px-4 py-3 border-2 border-gray-200 rounded-xl text-sm focus:border-blue-500 focus:ring-4 focus:ring-blue-100 transition-all"
                                    required>
                            </div>

                            <!-- Search Button -->
                            <div class="md:col-span-2">
                                <button type="submit" class="w-full py-3 px-6 bg-gradient-to-r from-yellow-400 to-yellow-500 hover:from-yellow-500 hover:to-yellow-600 text-yellow-900 font-bold rounded-xl shadow-lg hover:shadow-xl transition-all hover:-translate-y-0.5">
                                    <i class="bi bi-search me-1"></i> Tìm vé
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>

            <!-- Benefits -->
            <div class="max-w-4xl mx-auto mt-8 grid grid-cols-2 md:grid-cols-4 gap-4">
                <div class="flex items-center gap-2 text-white/90 text-sm">
                    <i class="bi bi-check-circle-fill text-green-400"></i>
                    <span>Chắc chắn có chỗ</span>
                </div>
                <div class="flex items-center gap-2 text-white/90 text-sm">
                    <i class="bi bi-headphones text-blue-300"></i>
                    <span>Hỗ trợ 24/7</span>
                </div>
                <div class="flex items-center gap-2 text-white/90 text-sm">
                    <i class="bi bi-star-fill text-yellow-400"></i>
                    <span>Nhiều ưu đãi</span>
                </div>
                <div class="flex items-center gap-2 text-white/90 text-sm">
                    <i class="bi bi-shield-check text-green-400"></i>
                    <span>Thanh toán an toàn</span>
                </div>
            </div>
        </div>
    </div>
</div>

