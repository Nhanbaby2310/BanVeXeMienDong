@{
    var breadcrumbs = ViewBag.Breadcrumbs as List<(string Title, string Url)>;
}

@if (breadcrumbs != null && breadcrumbs.Count > 0)
{
    <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-3">
        <ol class="flex items-center gap-1.5 text-sm flex-wrap">
            <li>
                <a href="/" class="text-gray-400 hover:text-blue-600 transition-colors">
                    <i class="bi bi-house-door"></i>
                </a>
            </li>
            @foreach (var item in breadcrumbs)
            {
                <li class="flex items-center gap-1.5">
                    <i class="bi bi-chevron-right text-gray-300 text-xs"></i>
                    @if (item == breadcrumbs.Last())
                    {
                        <span class="font-medium text-gray-700">@item.Title</span>
                    }
                    else
                    {
                        <a href="@item.Url" class="text-gray-400 hover:text-blue-600 transition-colors">@item.Title</a>
                    }
                </li>
            }
        </ol>
    </nav>
}
