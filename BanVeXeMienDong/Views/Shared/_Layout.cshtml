<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Bán Vé Xe Miền Đông</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">

    <link rel="stylesheet" href="~/css/navbar-modern.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/animations.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/style-modern.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/BanVeXeMienDong.styles.css" asp-append-version="true" />
</head>

<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark modern-navbar">
            <div class="container-fluid navbar-container">

                <!-- Logo -->
                <a class="navbar-brand modern-brand" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-bus-front"></i>
                    <span>Bán Vé Xe</span>
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-lg-inline-flex justify-content-end">
                    <ul class="navbar-nav ms-auto align-items-center navbar-menu">

                        <!-- Mua vé mới -->
                        <li class="nav-item">
                            <a class="nav-link menu-item" asp-controller="Ticket" asp-action="SelectDateTime">
                                <i class="bi bi-plus-circle"></i>
                                <span>Mua vé mới</span>
                            </a>
                        </li>

                        @if (Context.Session.GetString("user") != null)
                        {
                            <!-- Giỏ Hàng -->
                            <li class="nav-item">
                                <a class="nav-link menu-item cart-menu-item" href="/Cart/Index">
                                    <i class="bi bi-bag"></i>
                                    <span>Giỏ Hàng</span>
                                    <span class="cart-badge">
                                        @await Component.InvokeAsync("CartCount")
                                    </span>
                                </a>
                            </li>

                            <!-- Admin Menu -->
                            @if (Context.Session.GetString("role") == "Admin")
                            {
                                <li class="nav-item">
                                    <a class="nav-link menu-item admin-item" href="/Admin/Index">
                                        <i class="bi bi-shield-check"></i>
                                        <span>Admin</span>
                                    </a>
                                </li>
                            }
                        }

                        <!-- Divider -->
                        @if (Context.Session.GetString("user") != null)
                        {
                            <li class="nav-item divider"></li>
                        }

                        <!-- User Section -->
                        @if (Context.Session.GetString("user") == null)
                        {
                            <li class="nav-item">
                                <a class="nav-link menu-item login-btn" href="/Account/Login">
                                    <i class="bi bi-box-arrow-in-right"></i>
                                    <span>Đăng nhập</span>
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link menu-item register-btn" href="/Account/Register">
                                    <i class="bi bi-person-plus"></i>
                                    <span>Đăng ký</span>
                                </a>
                            </li>
                        }
                        else
                        {
                            <!-- User Badge -->
                            <li class="nav-item user-section">
                                <div class="user-info-badge">
                                    <i class="bi bi-person-circle"></i>
                                    <span class="username">@Context.Session.GetString("user")</span>
                                </div>
                            </li>

                            <!-- Đăng xuất -->
                            <li class="nav-item">
                                <a class="nav-link menu-item logout-btn" href="/Account/Logout">
                                    <i class="bi bi-box-arrow-right"></i>
                                    <span>Đăng xuất</span>
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <style>
        .admin-link {
            background-color: #f5576c;
            color: white !important;
            border-radius: 6px;
            padding: 8px 12px !important;
            transition: all 0.3s;
        }

        .admin-link:hover {
            background-color: #e74c63;
            transform: scale(1.05);
        }

        .cart-link {
            position: relative;
        }

        .cart-badge {
            position: absolute;
            top: -5px;
            right: -5px;
            background: #ff6b6b;
            color: white;
            border-radius: 50%;
            width: 20px;
            height: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 11px;
            font-weight: bold;
        }

        .user-info {
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .role-badge {
            background-color: #e7f5ff;
            color: #1971c2;
            padding: 2px 8px;
            border-radius: 12px;
            font-size: 11px;
            font-weight: 600;
            text-transform: uppercase;
        }
    </style>


    <main role="main" class="pb-3">
        <div class="container">
            @RenderBody()
        </div>
    </main>

    <!-- Footer -->
    <footer class="site-footer">
        <div class="footer-main">
            <div class="footer-container">
                <!-- Column 1: About -->
                <div class="footer-col">
                    <div class="footer-brand">
                        <i class="bi bi-bus-front"></i>
                        <span>Bán Vé Xe Miền Đông</span>
                    </div>
                    <p class="footer-desc">
                        Hệ thống đặt vé xe khách trực tuyến hàng đầu Việt Nam. 
                        Cam kết giá tốt nhất, dịch vụ chất lượng cao và hỗ trợ 24/7.
                    </p>
                    <div class="footer-social">
                        <a href="#" title="Facebook"><i class="bi bi-facebook"></i></a>
                        <a href="#" title="YouTube"><i class="bi bi-youtube"></i></a>
                        <a href="#" title="Instagram"><i class="bi bi-instagram"></i></a>
                        <a href="#" title="TikTok"><i class="bi bi-tiktok"></i></a>
                    </div>
                </div>

                <!-- Column 2: About Us -->
                <div class="footer-col">
                    <h4>Về Chúng Tôi</h4>
                    <ul>
                        <li><a href="#">Giới thiệu</a></li>
                        <li><a href="#">Tuyển dụng</a></li>
                        <li><a href="#">Tin tức</a></li>
                        <li><a href="#">Liên hệ hợp tác</a></li>
                        <li><a href="#">Quy chế hoạt động</a></li>
                    </ul>
                </div>

                <!-- Column 3: Support -->
                <div class="footer-col">
                    <h4>Hỗ Trợ</h4>
                    <ul>
                        <li><a href="#">Hướng dẫn đặt vé</a></li>
                        <li><a href="#">Chính sách hủy vé</a></li>
                        <li><a href="#">Chính sách bảo mật</a></li>
                        <li><a href="#">Điều khoản sử dụng</a></li>
                        <li><a href="#">Câu hỏi thường gặp</a></li>
                    </ul>
                </div>

                <!-- Column 4: Contact -->
                <div class="footer-col">
                    <h4>Liên Hệ</h4>
                    <ul class="footer-contact">
                        <li>
                            <i class="bi bi-telephone-fill"></i>
                            <span>Hotline: <strong>1900 6067</strong></span>
                        </li>
                        <li>
                            <i class="bi bi-envelope-fill"></i>
                            <span>hotro@banvexemiendong.vn</span>
                        </li>
                        <li>
                            <i class="bi bi-geo-alt-fill"></i>
                            <span>292 Đinh Bộ Lĩnh, P.26, Q. Bình Thạnh, TP.HCM</span>
                        </li>
                        <li>
                            <i class="bi bi-clock-fill"></i>
                            <span>Hỗ trợ: 06:00 - 22:00 hàng ngày</span>
                        </li>
                    </ul>
                </div>
            </div>
        </div>

        <!-- Footer Bottom -->
        <div class="footer-bottom">
            <div class="footer-container">
                <div class="footer-bottom-content">
                    <p>&copy; 2024 Bán Vé Xe Miền Đông. Tất cả quyền được bảo lưu.</p>
                    <div class="footer-payment">
                        <span>Chấp nhận thanh toán:</span>
                        <i class="bi bi-credit-card-2-front" title="Visa/Mastercard"></i>
                        <i class="bi bi-bank" title="Chuyển khoản"></i>
                        <i class="bi bi-phone" title="Ví điện tử"></i>
                        <i class="bi bi-cash-coin" title="Tiền mặt"></i>
                    </div>
                </div>
            </div>
        </div>
    </footer>

    <style>
        /* ===== FOOTER STYLES ===== */
        .site-footer {
            background: linear-gradient(135deg, #1a252f 0%, #2c3e50 100%);
            color: #bdc3c7;
            margin-top: 60px;
        }

        .footer-main {
            padding: 50px 0 30px;
        }

        .footer-container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 20px;
            display: grid;
            grid-template-columns: 1.5fr 1fr 1fr 1.2fr;
            gap: 40px;
        }

        .footer-brand {
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 20px;
            font-weight: 700;
            color: white;
            margin-bottom: 15px;
        }

        .footer-brand i {
            font-size: 24px;
            color: #e74c3c;
        }

        .footer-desc {
            font-size: 14px;
            line-height: 1.7;
            color: #95a5a6;
            margin-bottom: 20px;
        }

        .footer-social {
            display: flex;
            gap: 12px;
        }

        .footer-social a {
            width: 38px;
            height: 38px;
            border-radius: 50%;
            background: rgba(255, 255, 255, 0.1);
            display: flex;
            align-items: center;
            justify-content: center;
            color: #ecf0f1;
            font-size: 16px;
            transition: all 0.3s;
            text-decoration: none;
        }

        .footer-social a:hover {
            background: #e74c3c;
            color: white;
            transform: translateY(-3px);
        }

        .footer-col h4 {
            color: white;
            font-size: 16px;
            font-weight: 700;
            margin-bottom: 20px;
            position: relative;
            padding-bottom: 10px;
        }

        .footer-col h4::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 0;
            width: 30px;
            height: 3px;
            background: #e74c3c;
            border-radius: 2px;
        }

        .footer-col ul {
            list-style: none;
            padding: 0;
            margin: 0;
        }

        .footer-col ul li {
            margin-bottom: 10px;
        }

        .footer-col ul li a {
            color: #95a5a6;
            text-decoration: none;
            font-size: 14px;
            transition: all 0.3s;
            display: inline-block;
        }

        .footer-col ul li a:hover {
            color: #e74c3c;
            transform: translateX(5px);
        }

        .footer-contact li {
            display: flex;
            align-items: flex-start;
            gap: 10px;
            margin-bottom: 14px !important;
            font-size: 14px;
        }

        .footer-contact li i {
            color: #e74c3c;
            font-size: 16px;
            margin-top: 2px;
            flex-shrink: 0;
        }

        .footer-bottom {
            border-top: 1px solid rgba(255, 255, 255, 0.1);
            padding: 20px 0;
        }

        .footer-bottom .footer-container {
            display: flex;
            justify-content: center;
        }

        .footer-bottom-content {
            display: flex;
            justify-content: space-between;
            align-items: center;
            width: 100%;
            max-width: 1200px;
        }

        .footer-bottom-content p {
            margin: 0;
            font-size: 13px;
            color: #7f8c8d;
        }

        .footer-payment {
            display: flex;
            align-items: center;
            gap: 12px;
            font-size: 13px;
            color: #7f8c8d;
        }

        .footer-payment i {
            font-size: 20px;
            color: #95a5a6;
            transition: color 0.3s;
        }

        .footer-payment i:hover {
            color: #e74c3c;
        }

        @@media (max-width: 992px) {
            .footer-container {
                grid-template-columns: 1fr 1fr;
                gap: 30px;
            }
        }

        @@media (max-width: 576px) {
            .footer-container {
                grid-template-columns: 1fr;
                gap: 25px;
            }

            .footer-bottom-content {
                flex-direction: column;
                gap: 12px;
                text-align: center;
            }

            .footer-main {
                padding: 30px 0 20px;
            }
        }
    </style>

    <!-- FIX LỖI SCRIPT -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/cart-update.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>