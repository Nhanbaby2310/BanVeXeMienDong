<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Bến Xe Miền Đông</title>

    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        primary: { 50: '#eff6ff', 100: '#dbeafe', 200: '#bfdbfe', 300: '#93c5fd', 400: '#60a5fa', 500: '#3b82f6', 600: '#2563eb', 700: '#1d4ed8', 800: '#1e40af', 900: '#1e3a5f' },
                        accent: { 50: '#fef2f2', 100: '#fee2e2', 400: '#f87171', 500: '#ef4444', 600: '#dc2626', 700: '#b91c1c' },
                        success: { 500: '#22c55e', 600: '#16a34a' },
                        warning: { 400: '#fbbf24', 500: '#f59e0b' }
                    }
                }
            }
        }
    </script>

    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">

    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">

    <style>
        * { font-family: 'Inter', sans-serif; }
        .glass { backdrop-filter: blur(12px); background: rgba(255,255,255,0.85); }
        .gradient-primary { background: linear-gradient(135deg, #1e40af 0%, #3b82f6 50%, #60a5fa 100%); }
        .gradient-accent { background: linear-gradient(135deg, #dc2626 0%, #ef4444 100%); }
        .hover-lift { transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); }
        .hover-lift:hover { transform: translateY(-4px); box-shadow: 0 20px 40px rgba(0,0,0,0.12); }
        .nav-scrolled { box-shadow: 0 4px 20px rgba(0,0,0,0.1); }
        .toast-slide-in { animation: slideIn 0.4s ease; }
        .toast-slide-out { animation: slideOut 0.3s ease forwards; }
        @@keyframes slideIn { from { transform: translateX(100%); opacity: 0; } to { transform: translateX(0); opacity: 1; } }
        @@keyframes slideOut { from { transform: translateX(0); opacity: 1; } to { transform: translateX(100%); opacity: 0; } }
        @@keyframes progress { from { width: 100%; } to { width: 0%; } }
    </style>
</head>

<body class="bg-gray-50 min-h-screen flex flex-col">
    <!-- Promo Banner -->
    <div class="bg-gradient-to-r from-blue-900 via-blue-800 to-blue-700 text-white text-center py-2 text-sm font-medium">
        <span>🎉 Ưu đãi đặc biệt: Giảm 30% cho chuyến đầu tiên | Hotline: <strong>1900 6067</strong></span>
    </div>

    <!-- Navbar -->
    <nav id="mainNav" class="bg-white sticky top-0 z-50 border-b border-gray-100 transition-all duration-300">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex items-center justify-between h-16">
                <!-- Logo -->
                <a href="/" class="flex items-center gap-2 group">
                    <div class="w-10 h-10 rounded-xl gradient-primary flex items-center justify-center">
                        <i class="bi bi-bus-front text-white text-xl"></i>
                    </div>
                    <span class="text-xl font-bold text-gray-900 group-hover:text-blue-600 transition-colors hidden sm:block">Bến Xe Miền Đông</span>
                </a>

                <!-- Desktop Menu -->
                <div class="hidden md:flex items-center gap-1">
                    <a href="/Ticket/SelectRoute" class="px-4 py-2 text-sm font-medium text-gray-700 hover:text-blue-600 hover:bg-blue-50 rounded-lg transition-all">
                        <i class="bi bi-search me-1"></i> Tìm vé
                    </a>

                    @if (Context.Session.GetString("user") != null)
                    {
                        <a href="/Checkout/MyOrders" class="px-4 py-2 text-sm font-medium text-gray-700 hover:text-blue-600 hover:bg-blue-50 rounded-lg transition-all">
                            <i class="bi bi-receipt me-1"></i> Đơn hàng
                        </a>
                        <a href="/Cart/Index" class="relative px-4 py-2 text-sm font-medium text-gray-700 hover:text-blue-600 hover:bg-blue-50 rounded-lg transition-all">
                            <i class="bi bi-bag me-1"></i> Giỏ hàng
                            <span class="absolute -top-1 -right-1 bg-red-500 text-white text-xs w-5 h-5 rounded-full flex items-center justify-center font-bold">
                                @await Component.InvokeAsync("CartCount")
                            </span>
                        </a>

                        @if (Context.Session.GetString("role") == "Admin")
                        {
                            <a href="/Admin/Index" class="px-4 py-2 text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 rounded-lg transition-all">
                                <i class="bi bi-shield-check me-1"></i> Admin
                            </a>
                        }

                        <div class="h-6 w-px bg-gray-200 mx-2"></div>

                        <a href="/Account/Profile" class="flex items-center gap-2 px-3 py-2 text-sm font-medium text-gray-700 hover:bg-gray-100 rounded-lg transition-all">
                            <div class="w-8 h-8 rounded-full bg-blue-100 flex items-center justify-center">
                                <i class="bi bi-person text-blue-600"></i>
                            </div>
                            <span>@Context.Session.GetString("user")</span>
                        </a>
                        <a href="/Account/Logout" class="px-3 py-2 text-sm font-medium text-red-600 hover:bg-red-50 rounded-lg transition-all">
                            <i class="bi bi-box-arrow-right"></i>
                        </a>
                    }
                    else
                    {
                        <div class="h-6 w-px bg-gray-200 mx-2"></div>
                        <a href="/Account/Login" class="px-4 py-2 text-sm font-medium text-gray-700 hover:text-blue-600 border border-gray-200 hover:border-blue-300 rounded-lg transition-all">
                            Đăng nhập
                        </a>
                        <a href="/Account/Register" class="px-4 py-2 text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 rounded-lg transition-all">
                            Đăng ký
                        </a>
                    }
                </div>

                <!-- Mobile Menu Button -->
                <button id="mobileMenuBtn" class="md:hidden p-2 rounded-lg hover:bg-gray-100">
                    <i class="bi bi-list text-2xl"></i>
                </button>
            </div>
        </div>

        <!-- Mobile Menu -->
        <div id="mobileMenu" class="hidden md:hidden border-t border-gray-100 bg-white pb-4 px-4">
            <div class="flex flex-col gap-1 pt-3">
                <a href="/Ticket/SelectRoute" class="px-4 py-3 text-sm font-medium text-gray-700 hover:bg-blue-50 rounded-lg"><i class="bi bi-search me-2"></i>Tìm vé</a>
                @if (Context.Session.GetString("user") != null)
                {
                    <a href="/Checkout/MyOrders" class="px-4 py-3 text-sm font-medium text-gray-700 hover:bg-blue-50 rounded-lg"><i class="bi bi-receipt me-2"></i>Đơn hàng</a>
                    <a href="/Cart/Index" class="px-4 py-3 text-sm font-medium text-gray-700 hover:bg-blue-50 rounded-lg"><i class="bi bi-bag me-2"></i>Giỏ hàng</a>
                    <a href="/Account/Profile" class="px-4 py-3 text-sm font-medium text-gray-700 hover:bg-blue-50 rounded-lg"><i class="bi bi-person me-2"></i>Hồ sơ</a>
                    @if (Context.Session.GetString("role") == "Admin")
                    {
                        <a href="/Admin/Index" class="px-4 py-3 text-sm font-medium text-blue-600 hover:bg-blue-50 rounded-lg"><i class="bi bi-shield-check me-2"></i>Admin</a>
                    }
                    <a href="/Account/Logout" class="px-4 py-3 text-sm font-medium text-red-600 hover:bg-red-50 rounded-lg"><i class="bi bi-box-arrow-right me-2"></i>Đăng xuất</a>
                }
                else
                {
                    <a href="/Account/Login" class="px-4 py-3 text-sm font-medium text-gray-700 hover:bg-blue-50 rounded-lg"><i class="bi bi-box-arrow-in-right me-2"></i>Đăng nhập</a>
                    <a href="/Account/Register" class="px-4 py-3 text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 rounded-lg text-center"><i class="bi bi-person-plus me-2"></i>Đăng ký</a>
                }
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <main class="flex-1">
        @RenderBody()
    </main>

    <!-- Footer -->
    <footer class="bg-gray-900 text-gray-300 mt-auto">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
                <!-- Brand -->
                <div>
                    <div class="flex items-center gap-2 mb-4">
                        <div class="w-10 h-10 rounded-xl gradient-primary flex items-center justify-center">
                            <i class="bi bi-bus-front text-white text-lg"></i>
                        </div>
                        <span class="text-lg font-bold text-white">Bến Xe Miền Đông</span>
                    </div>
                    <p class="text-sm text-gray-400 leading-relaxed mb-4">Hệ thống đặt vé xe khách trực tuyến uy tín hàng đầu Việt Nam. An toàn - Tiện lợi - Giá tốt nhất.</p>
                    <div class="flex gap-3">
                        <a href="#" class="w-9 h-9 rounded-full bg-gray-800 hover:bg-blue-600 flex items-center justify-center transition-colors"><i class="bi bi-facebook"></i></a>
                        <a href="#" class="w-9 h-9 rounded-full bg-gray-800 hover:bg-red-600 flex items-center justify-center transition-colors"><i class="bi bi-youtube"></i></a>
                        <a href="#" class="w-9 h-9 rounded-full bg-gray-800 hover:bg-pink-600 flex items-center justify-center transition-colors"><i class="bi bi-instagram"></i></a>
                        <a href="#" class="w-9 h-9 rounded-full bg-gray-800 hover:bg-gray-600 flex items-center justify-center transition-colors"><i class="bi bi-tiktok"></i></a>
                    </div>
                </div>

                <!-- Links -->
                <div>
                    <h4 class="text-white font-semibold mb-4">Về Chúng Tôi</h4>
                    <ul class="space-y-2 text-sm">
                        <li><a href="#" class="hover:text-white transition-colors">Giới thiệu</a></li>
                        <li><a href="#" class="hover:text-white transition-colors">Tuyển dụng</a></li>
                        <li><a href="#" class="hover:text-white transition-colors">Tin tức</a></li>
                        <li><a href="#" class="hover:text-white transition-colors">Liên hệ hợp tác</a></li>
                    </ul>
                </div>

                <!-- Support -->
                <div>
                    <h4 class="text-white font-semibold mb-4">Hỗ Trợ</h4>
                    <ul class="space-y-2 text-sm">
                        <li><a href="#" class="hover:text-white transition-colors">Hướng dẫn đặt vé</a></li>
                        <li><a href="#" class="hover:text-white transition-colors">Chính sách hủy vé</a></li>
                        <li><a href="#" class="hover:text-white transition-colors">Chính sách bảo mật</a></li>
                        <li><a href="#" class="hover:text-white transition-colors">Câu hỏi thường gặp</a></li>
                    </ul>
                </div>

                <!-- Contact -->
                <div>
                    <h4 class="text-white font-semibold mb-4">Liên Hệ</h4>
                    <ul class="space-y-3 text-sm">
                        <li class="flex items-center gap-2"><i class="bi bi-telephone-fill text-blue-400"></i> <strong class="text-white">1900 6067</strong></li>
                        <li class="flex items-center gap-2"><i class="bi bi-envelope-fill text-blue-400"></i> hotro&#64;benxemiendong.vn</li>
                        <li class="flex items-start gap-2"><i class="bi bi-geo-alt-fill text-blue-400 mt-0.5"></i> 292 Đinh Bộ Lĩnh, P.26, Q.Bình Thạnh, TP.HCM</li>
                        <li class="flex items-center gap-2"><i class="bi bi-clock-fill text-blue-400"></i> 06:00 - 22:00 hàng ngày</li>
                    </ul>
                </div>
            </div>
        </div>

        <!-- Bottom -->
        <div class="border-t border-gray-800">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4 flex flex-col sm:flex-row items-center justify-between gap-3">
                <p class="text-xs text-gray-500">&copy; 2024 Bến Xe Miền Đông. Tất cả quyền được bảo lưu.</p>
                <div class="flex items-center gap-3 text-gray-500 text-xs">
                    <span>Thanh toán:</span>
                    <i class="bi bi-credit-card text-lg"></i>
                    <i class="bi bi-bank text-lg"></i>
                    <i class="bi bi-phone text-lg"></i>
                    <i class="bi bi-cash-coin text-lg"></i>
                </div>
            </div>
        </div>
    </footer>

    <!-- Toast Container -->
    <div id="toast-container" class="fixed top-20 right-4 z-[99999] flex flex-col gap-3 pointer-events-none"></div>

    <!-- Scripts -->
    <script>
        // Mobile menu toggle
        document.getElementById('mobileMenuBtn')?.addEventListener('click', function() {
            document.getElementById('mobileMenu').classList.toggle('hidden');
        });

        // Navbar scroll effect
        window.addEventListener('scroll', function() {
            const nav = document.getElementById('mainNav');
            if (window.scrollY > 10) {
                nav.classList.add('nav-scrolled');
            } else {
                nav.classList.remove('nav-scrolled');
            }
        });

        // Toast system
        function showToast(message, type = 'success') {
            const container = document.getElementById('toast-container');
            const colors = { success: 'border-green-500 bg-green-50', error: 'border-red-500 bg-red-50', info: 'border-blue-500 bg-blue-50' };
            const icons = { success: 'bi-check-circle-fill text-green-600', error: 'bi-exclamation-circle-fill text-red-600', info: 'bi-info-circle-fill text-blue-600' };

            const toast = document.createElement('div');
            toast.className = `pointer-events-auto flex items-center gap-3 px-4 py-3 rounded-xl border-l-4 shadow-lg ${colors[type]} toast-slide-in`;
            toast.innerHTML = `
                <i class="bi ${icons[type]} text-lg"></i>
                <span class="text-sm font-medium text-gray-800 flex-1">${message}</span>
                <button onclick="this.parentElement.classList.add('toast-slide-out'); setTimeout(() => this.parentElement.remove(), 300);" class="text-gray-400 hover:text-gray-600">&times;</button>
            `;
            container.appendChild(toast);
            setTimeout(() => { if (toast.parentElement) { toast.classList.add('toast-slide-out'); setTimeout(() => toast.remove(), 300); } }, 4000);
        }

        // Auto-convert alerts to toasts
        document.addEventListener('DOMContentLoaded', function() {
            document.querySelectorAll('[data-toast-success]').forEach(el => { showToast(el.dataset.toastSuccess, 'success'); el.remove(); });
            document.querySelectorAll('[data-toast-error]').forEach(el => { showToast(el.dataset.toastError, 'error'); el.remove(); });
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
