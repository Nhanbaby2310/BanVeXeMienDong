@{
    ViewData["Title"] = "Chọn hạng xe";
}

<link rel="stylesheet" href="~/css/bus-class.css" asp-append-version="true" />

<style>
    .bus-selection-container {
        max-width: 1000px;
        margin: 3rem auto;
        padding: 2rem;
    }

    .step-indicator {
        display: flex;
        justify-content: space-between;
        margin-bottom: 2rem;
        position: relative;
    }

    .step {
        flex: 1;
        text-align: center;
        position: relative;
    }

    .step-number {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background: #ddd;
        color: #666;
        font-weight: bold;
        margin: 0 auto 0.5rem;
    }

    .step.active .step-number {
        background: linear-gradient(135deg, #e74c3c 0%, #c0392b 100%);
        color: white;
    }

    .step.completed .step-number {
        background: #27ae60;
        color: white;
    }

    .step-label {
        font-size: 0.9rem;
        color: #666;
    }

    .route-header {
        text-align: center;
        padding: 1.5rem;
        background: linear-gradient(135deg, #ffe8e8 0%, #fff5f5 100%);
        border-radius: 12px;
        margin-bottom: 2rem;
    }

    .route-text {
        font-size: 1.6rem;
        font-weight: bold;
        color: #2c3e50;
    }

    .date-text {
        font-size: 1rem;
        color: #7f8c8d;
        margin-top: 0.5rem;
    }

    .bus-class-selection {
        margin: 2rem 0;
    }

    .row {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 2rem;
    }

    .bus-class-card {
        position: relative;
        text-decoration: none;
        color: inherit;
    }

    .action-buttons {
        margin-top: 2rem;
        display: flex;
        gap: 1rem;
        justify-content: center;
    }

    .btn {
        padding: 0.75rem 2rem;
        border: none;
        border-radius: 8px;
        font-size: 1rem;
        cursor: pointer;
        transition: all 0.3s ease;
        text-decoration: none;
        display: inline-block;
    }

    .btn-primary {
        background: linear-gradient(135deg, #e74c3c 0%, #c0392b 100%);
        color: white;
    }

    .btn-primary:hover {
        transform: scale(1.05);
        box-shadow: 0 5px 15px rgba(231, 76, 60, 0.4);
    }

    .btn-secondary {
        background: #ddd;
        color: #2c3e50;
    }

    .btn-secondary:hover {
        background: #bbb;
    }

    .page-title {
        text-align: center;
        font-size: 2rem;
        color: #2c3e50;
        margin-bottom: 1rem;
    }

    .page-title i {
        margin-right: 0.5rem;
        color: #e74c3c;
    }
</style>

<div class="bus-selection-container">
    <div class="page-title">
        <i class="bi bi-bus-front"></i> Chọn Hạng Xe
    </div>

    <!-- Step Indicator -->
    <div class="step-indicator">
        <div class="step completed">
            <div class="step-number">1</div>
            <div class="step-label">Tuyến Đường</div>
        </div>
        <div class="step completed">
            <div class="step-number">2</div>
            <div class="step-label">Ngày & Giờ</div>
        </div>
        <div class="step active">
            <div class="step-number">3</div>
            <div class="step-label">Hạng Xe</div>
        </div>
        <div class="step">
            <div class="step-number">4</div>
            <div class="step-label">Chọn Ghế</div>
        </div>
    </div>

    <!-- Route & DateTime Header -->
    <div class="route-header">
        <div style="font-size: 0.9rem; color: #7f8c8d; text-transform: uppercase;">Chi Tiết Chuyến Đi</div>
        <div class="route-text">
            @ViewBag.DiemDi <span style="color: #e74c3c; margin: 0 0.5rem;">→</span> @ViewBag.DiemDen
        </div>
        <div class="date-text">
            @if (ViewBag.NgayGio != null)
            {
                var ngayGio = (DateTime)ViewBag.NgayGio;
                <text>
                <i class="bi bi-calendar-event"></i> @ngayGio.ToString("dd/MM/yyyy") - <i class="bi bi-clock"></i> @ngayGio.ToString("HH:mm")
                </text>
            }
        </div>
    </div>

    <div class="bus-class-selection">
        <div class="row">
            <form method="post" action="/Ticket/ConfirmBusClass" style="width: 100%;">
                @Html.AntiForgeryToken()
                <input type="hidden" name="diemDi" value="@(ViewBag.DiemDi ?? "")" />
                <input type="hidden" name="diemDen" value="@(ViewBag.DiemDen ?? "")" />
                <input type="hidden" name="ngayGio" value="@(ViewBag.NgayGio?.ToString("yyyy-MM-ddTHH:mm") ?? "")" />
                <button type="submit" name="busClassValue" value="0" class="bus-class-card standard-card" style="border: none; background: none; padding: 0; width: 100%; cursor: pointer;">
                    <div class="bus-class-icon">
                        <i class="bi bi-bus-front"></i>
                    </div>
                    <h3>Xe Thường</h3>
                    <p class="description">Xe khách tiêu chuẩn</p>
                    <ul class="features-list">
                        <li><i class="bi bi-check-circle"></i> 10 hàng ghế</li>
                        <li><i class="bi bi-check-circle"></i> 4 ghế mỗi hàng</li>
                        <li><i class="bi bi-check-circle"></i> Tổng 40 ghế</li>
                        <li><i class="bi bi-check-circle"></i> Giá cố định</li>
                    </ul>
                    <div class="price-badge" style="font-size: 1.3rem; font-weight: bold; color: #3498db; margin-top: 1rem;">💰 300,000 VND</div>
                </button>
            </form>
        </div>

        <div class="row">
            <form method="post" action="/Ticket/ConfirmBusClass" style="width: 100%;">
                @Html.AntiForgeryToken()
                <input type="hidden" name="diemDi" value="@(ViewBag.DiemDi ?? "")" />
                <input type="hidden" name="diemDen" value="@(ViewBag.DiemDen ?? "")" />
                <input type="hidden" name="ngayGio" value="@(ViewBag.NgayGio?.ToString("yyyy-MM-ddTHH:mm") ?? "")" />
                <button type="submit" name="busClassValue" value="1" class="bus-class-card premium-card" style="border: none; background: none; padding: 0; width: 100%; cursor: pointer;">
                    <div class="premium-badge">
                        <i class="bi bi-star-fill"></i> VIP
                    </div>
                    <div class="bus-class-icon">
                        <i class="bi bi-bus-front"></i>
                    </div>
                    <h3>Xe Cao Cấp</h3>
                    <p class="description">Xe khách cao cấp VIP</p>
                    <ul class="features-list">
                        <li><i class="bi bi-check-circle"></i> 8 hàng ghế</li>
                        <li><i class="bi bi-check-circle"></i> 2 ghế mỗi hàng</li>
                        <li><i class="bi bi-check-circle"></i> Tổng 16 ghế</li>
                        <li><i class="bi bi-check-circle"></i> Ghế rộng rãi</li>
                    </ul>
                    <div class="price-badge premium" style="font-size: 1.3rem; font-weight: bold; color: #f39c12; margin-top: 1rem;">💰 400,000 VND</div>
                </button>
            </form>
        </div>
    </div>

    <div class="action-buttons">
        <a href="/Ticket/SelectDateTime?diemDi=@(ViewBag.DiemDi)&diemDen=@(ViewBag.DiemDen)" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i> Quay Lại
        </a>
    </div>
</div>

<script>
    // Make the entire card clickable
    document.querySelectorAll('.bus-class-card').forEach(card => {
        card.addEventListener('click', function(e) {
            if (e.target.closest('form')) {
                e.target.closest('form').submit();
            }
        });
    });
</script>
