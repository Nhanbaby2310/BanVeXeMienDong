@{
    ViewData["Title"] = "Chọn ngày và giờ đi";
}

<link rel="stylesheet" href="~/css/style-modern.css" asp-append-version="true" />

<style>
    .datetime-selection-container {
        max-width: 900px;
        margin: 3rem auto;
        padding: 2rem;
    }

    .step-indicator {
        display: flex;
        justify-content: space-between;
        margin-bottom: 2rem;
        position: relative;
    }

    .step {
        flex: 1;
        text-align: center;
        position: relative;
    }

    .step-number {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background: #ddd;
        color: #666;
        font-weight: bold;
        margin: 0 auto 0.5rem;
    }

    .step.active .step-number {
        background: linear-gradient(135deg, #e74c3c 0%, #c0392b 100%);
        color: white;
    }

    .step.completed .step-number {
        background: #27ae60;
        color: white;
    }

    .step-label {
        font-size: 0.9rem;
        color: #666;
    }

    .page-title {
        text-align: center;
        font-size: 2rem;
        color: #2c3e50;
        margin-bottom: 1rem;
    }

    .page-title i {
        margin-right: 0.5rem;
        color: #e74c3c;
    }

    .datetime-form {
        background: white;
        border: 2px solid #ddd;
        border-radius: 12px;
        padding: 2rem;
        margin-top: 2rem;
    }

    .form-group {
        margin-bottom: 1.5rem;
    }

    .form-label {
        display: block;
        font-weight: bold;
        color: #2c3e50;
        margin-bottom: 0.5rem;
        font-size: 1.1rem;
    }

    .form-control {
        width: 100%;
        padding: 0.75rem 1rem;
        border: 2px solid #ddd;
        border-radius: 8px;
        font-size: 1rem;
        transition: all 0.3s ease;
    }

    .form-control:focus {
        outline: none;
        border-color: #e74c3c;
        box-shadow: 0 0 5px rgba(231, 76, 60, 0.3);
    }

    .datetime-info {
        background: linear-gradient(135deg, #ffe8e8 0%, #fff5f5 100%);
        border: 2px solid #e74c3c;
        border-radius: 12px;
        padding: 1.5rem;
        margin-top: 2rem;
        text-align: center;
    }

    .selected-datetime {
        font-size: 1.5rem;
        font-weight: bold;
        color: #2c3e50;
        margin: 0.5rem 0;
    }

    .selected-datetime-label {
        color: #7f8c8d;
        font-size: 0.9rem;
        text-transform: uppercase;
    }

    .action-buttons {
        margin-top: 2rem;
        display: flex;
        gap: 1rem;
        justify-content: center;
    }

    .btn {
        padding: 0.75rem 2rem;
        border: none;
        border-radius: 8px;
        font-size: 1rem;
        cursor: pointer;
        transition: all 0.3s ease;
        text-decoration: none;
        display: inline-block;
    }

    .btn-primary {
        background: linear-gradient(135deg, #e74c3c 0%, #c0392b 100%);
        color: white;
    }

    .btn-primary:hover {
        transform: scale(1.05);
        box-shadow: 0 5px 15px rgba(231, 76, 60, 0.4);
    }

    .btn-primary:disabled {
        opacity: 0.5;
        cursor: not-allowed;
        transform: scale(1);
    }

    .form-row {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 1.5rem;
    }
</style>

<div class="datetime-selection-container">
    <div class="page-title">
        <i class="bi bi-calendar-event"></i> Chọn Ngày và Giờ Đi
    </div>

    <!-- Step Indicator -->
    <div class="step-indicator">
        <div class="step completed">
            <div class="step-number">1</div>
            <div class="step-label">Tuyến Đường</div>
        </div>
        <div class="step active">
            <div class="step-number">2</div>
            <div class="step-label">Ngày & Giờ</div>
        </div>
        <div class="step">
            <div class="step-number">3</div>
            <div class="step-label">Hạng Xe</div>
        </div>
        <div class="step">
            <div class="step-number">4</div>
            <div class="step-label">Chọn Ghế</div>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(ViewBag.DiemDi) && !string.IsNullOrEmpty(ViewBag.DiemDen))
    {
        <!-- Route Info -->
        <div style="background: linear-gradient(135deg, #ffe8e8 0%, #fff5f5 100%); border: 2px solid #e74c3c; border-radius: 12px; padding: 1.5rem; margin-bottom: 2rem; text-align: center;">
            <div style="font-size: 0.9rem; color: #7f8c8d; text-transform: uppercase;">Tuyến đường được chọn</div>
            <div style="font-size: 1.5rem; font-weight: bold; color: #2c3e50; margin-top: 0.5rem;">
                <i class="bi bi-geo-alt"></i> @ViewBag.DiemDi <span style="color: #e74c3c; margin: 0 0.5rem;">→</span> @ViewBag.DiemDen
            </div>
            <a href="/Ticket/SelectRoute" class="btn btn-link-change" style="margin-top: 0.8rem; display: inline-block; padding: 0.5rem 1rem; background: #e74c3c; color: white; text-decoration: none; border-radius: 6px; font-size: 0.9rem;">
                <i class="bi bi-pencil"></i> Thay đổi tuyến đường
            </a>
        </div>

        <form id="datetimeForm" method="post" action="/Ticket/SelectBusClass" class="datetime-form">
            @Html.AntiForgeryToken()
            @if (ViewBag.AvailableDateTimes != null && ViewBag.AvailableDateTimes.Count > 0)
            {
                <div class="form-group">
                    <label class="form-label">
                        <i class="bi bi-calendar3"></i> Chọn Ngày và Giờ Khởi Hành
                    </label>
                    <p style="color: #7f8c8d; font-size: 0.9rem; margin-bottom: 1rem;">
                        Có <strong>@ViewBag.AvailableDateTimes.Count</strong> chuyến xe khả dụng cho tuyến này
                    </p>

                    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(150px, 1fr)); gap: 1rem; margin-top: 1rem;">
                        @foreach (var dateTime in ViewBag.AvailableDateTimes)
                        {
                            var dt = (DateTime)dateTime;
                            var dateValue = dt.ToString("yyyy-MM-ddTHH:mm");
                            var displayText = dt.ToString("dd/MM") + " - " + dt.ToString("HH:mm");
                            var dayName = dt.ToString("dddd");

                            <label style="background: white; border: 2px solid #ddd; border-radius: 8px; padding: 1rem; cursor: pointer; text-align: center; transition: all 0.3s ease;" class="datetime-option">
                                <input type="radio" name="ngayGio" value="@dateValue" style="display: none;" />
                                <div style="font-size: 1.2rem; font-weight: bold; color: #2c3e50;">@dt.ToString("HH:mm")</div>
                                <div style="font-size: 0.9rem; color: #7f8c8d; margin-top: 0.3rem;">@dt.ToString("dd/MM")</div>
                                <div style="font-size: 0.8rem; color: #95a5a6; margin-top: 0.2rem;">@dayName</div>
                            </label>
                        }
                    </div>
                    <small style="color: #7f8c8d; margin-top: 0.5rem; display: block;">
                        <i class="bi bi-info-circle"></i> Chọn một chuyến xe từ danh sách trên
                    </small>
                </div>

                <!-- Selected DateTime Display -->
                <div id="selectedDisplay" style="display: none;" class="datetime-info">
                    <div class="selected-datetime-label">✅ Bạn đã chọn</div>
                    <div class="selected-datetime" id="selectedDateTime">--</div>
                </div>
            }
            else
            {
                <div style="background: #fff3cd; border: 2px solid #ffc107; border-radius: 12px; padding: 2rem; text-align: center; color: #856404;">
                    <i class="bi bi-exclamation-triangle"></i>
                    <p style="margin: 1rem 0 0 0; font-size: 1.1rem;"><strong>Không có chuyến xe nào</strong></p>
                    <p style="color: #7f8c8d; margin: 0.5rem 0 0 0;">cho tuyến @ViewBag.DiemDi - @ViewBag.DiemDen</p>
                </div>
            }

            <div class="action-buttons">
                <a href="/Ticket/SelectRoute" class="btn" style="background: #6c757d; color: white; text-decoration: none;">
                    <i class="bi bi-arrow-left"></i> Quay Lại Chọn Tuyến
                </a>
                <button type="submit" id="nextBtn" class="btn btn-primary" disabled>
                    <i class="bi bi-arrow-right"></i> Tiếp Theo
                </button>
            </div>

            <input type="hidden" name="diemDi" value="@ViewBag.DiemDi" />
            <input type="hidden" name="diemDen" value="@ViewBag.DiemDen" />
        </form>
    }
    else
    {
        <div style="text-align: center; padding: 2rem; background: #f0f0f0; border-radius: 8px;">
            <p><i class="bi bi-exclamation-circle"></i> Vui lòng chọn tuyến đường trước</p>
            <a href="/Ticket/SelectRoute" class="btn btn-primary" style="margin-top: 1rem; text-decoration: none;">
                <i class="bi bi-arrow-left"></i> Quay Lại Chọn Tuyến Đường
            </a>
        </div>
    }
</div>

<style>
    .datetime-option input:checked + .datetime-option-content,
    .datetime-option input[type="radio"]:checked ~ * {
        border-color: #e74c3c;
        background: linear-gradient(135deg, #ffe8e8 0%, #fff5f5 100%);
        box-shadow: 0 3px 10px rgba(231, 76, 60, 0.3);
    }

    .datetime-option:has(input[type="radio"]:checked) {
        border-color: #e74c3c;
        background: linear-gradient(135deg, #ffe8e8 0%, #fff5f5 100%);
        box-shadow: 0 3px 10px rgba(231, 76, 60, 0.3);
    }
</style>

<script>
    const datetimeOptions = document.querySelectorAll('input[name="ngayGio"]');
    const nextBtn = document.getElementById('nextBtn');
    const selectedDisplay = document.getElementById('selectedDisplay');
    const selectedDateTime = document.getElementById('selectedDateTime');

    datetimeOptions.forEach(option => {
        option.addEventListener('change', function() {
            if (this.value) {
                const date = new Date(this.value);
                const formatted = date.toLocaleDateString('vi-VN', {
                    weekday: 'long',
                    year: 'numeric',
                    month: 'long',
                    day: 'numeric'
                }) + ' - ' + date.toLocaleTimeString('vi-VN', {
                    hour: '2-digit',
                    minute: '2-digit'
                });

                selectedDateTime.textContent = formatted;
                selectedDisplay.style.display = 'block';
                nextBtn.disabled = false;

                // Auto submit form
                setTimeout(() => {
                    document.getElementById('datetimeForm').submit();
                }, 300);
            }
        });

        // Add click handler to label
        option.parentElement.addEventListener('click', function() {
            option.checked = true;
            option.dispatchEvent(new Event('change'));
        });
    });
</script>
