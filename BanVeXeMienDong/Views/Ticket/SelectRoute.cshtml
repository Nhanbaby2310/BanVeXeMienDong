@model List<BanVeXeMienDong.Models.Ticket>
@using BanVeXeMienDong.Models

@{
    ViewData["Title"] = "Danh sách vé xe - Bán Vé Xe Miền Đông";
}

<link rel="stylesheet" href="~/css/search-results-vexere.css" asp-append-version="true" />

<div class="page-container">
    <!-- Header -->
    <div class="vexere-header">
        <div class="header-left">
            <h1>🚌 Bán Vé Xe Miền Đông</h1>
        </div>
        <div class="header-right">
            <a href="/" class="header-btn">← Quay Lại</a>
        </div>
    </div>

    <!-- Search Form -->
    <div class="search-section" style="max-width: 1400px; margin: 0 auto 20px; background: white; border-radius: 12px; padding: 20px; box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);">
        <form method="get" action="/Ticket/SelectRoute" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 12px; align-items: flex-end;">
            <div style="display: flex; flex-direction: column; gap: 6px;">
                <label style="font-weight: 600; color: #374151; font-size: 13px;">Điểm đi</label>
                <select name="diemDi" style="padding: 10px 12px; border: 1px solid #d1d5db; border-radius: 8px; font-size: 14px; background: #f9fafb; color: #1f2937;">
                    <option value="">-- Chọn điểm đi --</option>
                    @if (ViewBag.Routes != null)
                    {
                        var routesList = (IEnumerable<dynamic>)ViewBag.Routes;
                        var fromPoints = routesList.Cast<dynamic>().Select(r => (string)r.DiemDi).Distinct().ToList();
                        foreach (var point in fromPoints)
                        {
                            if (ViewBag.DiemDi == point)
                            {
                                <option value="@point" selected>@point</option>
                            }
                            else
                            {
                                <option value="@point">@point</option>
                            }
                        }
                    }
                </select>
            </div>

            <div style="display: flex; flex-direction: column; gap: 6px;">
                <label style="font-weight: 600; color: #374151; font-size: 13px;">Điểm đến</label>
                <select name="diemDen" style="padding: 10px 12px; border: 1px solid #d1d5db; border-radius: 8px; font-size: 14px; background: #f9fafb; color: #1f2937;">
                    <option value="">-- Chọn điểm đến --</option>
                    @if (ViewBag.Routes != null)
                    {
                        var routesList = (IEnumerable<dynamic>)ViewBag.Routes;
                        var toPoints = routesList.Cast<dynamic>().Select(r => (string)r.DiemDen).Distinct().ToList();
                        foreach (var point in toPoints)
                        {
                            if (ViewBag.DiemDen == point)
                            {
                                <option value="@point" selected>@point</option>
                            }
                            else
                            {
                                <option value="@point">@point</option>
                            }
                        }
                    }
                </select>
            </div>

            <div style="display: flex; flex-direction: column; gap: 6px;">
                <label style="font-weight: 600; color: #374151; font-size: 13px;">Ngày đi</label>
                <input type="date" name="ngayDi" value="@ViewBag.NgayDi" style="padding: 10px 12px; border: 1px solid #d1d5db; border-radius: 8px; font-size: 14px; background: #f9fafb; color: #1f2937;">
            </div>

            <div style="display: flex; gap: 8px;">
                <button type="submit" class="search-btn" style="flex: 1; background: #fbbf24; color: #78350f; padding: 10px 16px; border: none; border-radius: 8px; font-weight: 700; cursor: pointer; transition: all 0.3s; font-size: 14px;">
                    <i class="bi bi-search"></i> Tìm Kiếm
                </button>
                <a href="/Ticket/SelectRoute" style="flex: 1; background: #6b7280; color: white; padding: 10px 16px; border: none; border-radius: 8px; font-weight: 700; cursor: pointer; transition: all 0.3s; font-size: 14px; text-decoration: none; display: flex; align-items: center; justify-content: center; gap: 6px;">
                    <i class="bi bi-arrow-clockwise"></i> Xóa Lọc
                </a>
            </div>
        </form>
    </div>

    <div class="search-results-container">
        <!-- Sidebar Filter -->
        <aside class="sidebar-filter">
            <div class="filter-section">
                <div class="filter-title expandable" onclick="toggleFilter(this)">
                    Giá Vé
                    <span class="expand-icon expanded">▼</span>
                </div>
                <div class="range-slider-container">
                    <div class="price-inputs">
                        <input type="number" id="minPrice" placeholder="Min" value="0">
                        <input type="number" id="maxPrice" placeholder="Max" value="5000000">
                    </div>
                    <input type="range" class="range-slider" id="priceRange" min="0" max="5000000" value="5000000">
                </div>
            </div>

            <div class="filter-section">
                <div class="filter-title expandable" onclick="toggleFilter(this)">
                    Loại Xe
                    <span class="expand-icon expanded">▼</span>
                </div>
                <div class="filter-options">
                    <label class="filter-option">
                        <input type="checkbox" value="limousine">
                        <span>Limousine</span>
                        <span class="count">12</span>
                    </label>
                    <label class="filter-option">
                        <input type="checkbox" value="giuong">
                        <span>Giường nằm</span>
                        <span class="count">8</span>
                    </label>
                    <label class="filter-option">
                        <input type="checkbox" value="thuong">
                        <span>Xe thường</span>
                        <span class="count">15</span>
                    </label>
                </div>
            </div>

            <div class="filter-section">
                <div class="filter-title expandable" onclick="toggleFilter(this)">
                    Tiện Ích
                    <span class="expand-icon expanded">▼</span>
                </div>
                <div class="filter-options">
                    <label class="filter-option">
                        <input type="checkbox" value="wifi">
                        <span>WiFi</span>
                        <span class="count">18</span>
                    </label>
                    <label class="filter-option">
                        <input type="checkbox" value="toilet">
                        <span>Toilet</span>
                        <span class="count">14</span>
                    </label>
                    <label class="filter-option">
                        <input type="checkbox" value="water">
                        <span>Nước uống</span>
                        <span class="count">10</span>
                    </label>
                    <label class="filter-option">
                        <input type="checkbox" value="food">
                        <span>Đồ ăn</span>
                        <span class="count">7</span>
                    </label>
                </div>
            </div>

            <div class="filter-section">
                <div class="filter-title expandable" onclick="toggleFilter(this)">
                    Điểm Đón
                    <span class="expand-icon expanded">▼</span>
                </div>
                <div class="filter-options">
                    <label class="filter-option">
                        <input type="checkbox" value="center">
                        <span>Trung tâm thành phố</span>
                        <span class="count">20</span>
                    </label>
                    <label class="filter-option">
                        <input type="checkbox" value="airport">
                        <span>Sân bay</span>
                        <span class="count">5</span>
                    </label>
                    <label class="filter-option">
                        <input type="checkbox" value="station">
                        <span>Bến xe</span>
                        <span class="count">12</span>
                    </label>
                </div>
            </div>

            <div class="filter-section">
                <div class="filter-title expandable" onclick="toggleFilter(this)">
                    Đánh Giá
                    <span class="expand-icon expanded">▼</span>
                </div>
                <div class="filter-options">
                    <label class="filter-option">
                        <input type="checkbox" value="5star">
                        <span>★★★★★ 4.5+</span>
                        <span class="count">8</span>
                    </label>
                    <label class="filter-option">
                        <input type="checkbox" value="4star">
                        <span>★★★★☆ 4.0-4.5</span>
                        <span class="count">12</span>
                    </label>
                    <label class="filter-option">
                        <input type="checkbox" value="3star">
                        <span>★★★☆☆ 3.5-4.0</span>
                        <span class="count">7</span>
                    </label>
                </div>
            </div>
        </aside>

        <!-- Results Section -->
        <section class="results-section">
            <!-- Promotion Banner -->
            <div class="promotion-banner">
                <span class="promo-icon">⚡</span>
                <span class="promo-text">FLASH SALE: Giảm đến 50% các chuyến xe trong 24 giờ tới</span>
            </div>

            <!-- Toolbar -->
            <div class="results-toolbar">
                <span class="results-count" id="resultsCount">Kết quả: ... chuyến xe</span>
                <div class="sort-options">
                    <button type="button" class="sort-btn active" onclick="sortResults('default')">Mặc định</button>
                    <button type="button" class="sort-btn" onclick="sortResults('price-asc')">Giá thấp</button>
                    <button type="button" class="sort-btn" onclick="sortResults('price-desc')">Giá cao</button>
                    <button type="button" class="sort-btn" onclick="sortResults('time-asc')">Sớm nhất</button>
                </div>
            </div>

            <!-- Result Cards -->
            <div id="resultsContainer">
                @if (Model != null && Model.Count > 0)
                {
                    var tickets = Model;
                    <script>
                        document.getElementById('resultsCount').textContent = `Kết quả: ${@tickets.Count} chuyến xe`;
                    </script>

                    @foreach (var ticket in tickets)
                    {
                        var rating = 4.5 + (Random.Shared.NextDouble() * 0.5);
                        var bookedCount = tickets.Count(t => t.DiemDi == ticket.DiemDi && t.DiemDen == ticket.DiemDen && t.NgayDi.Date == ticket.NgayDi.Date && t.NgayDi.TimeOfDay == ticket.NgayDi.TimeOfDay);
                        var tripKey = $"{ticket.DiemDi}-{ticket.DiemDen}-{ticket.NgayDi:yyyy-MM-dd HH:mm}";

                        <div class="result-card" data-price="@ticket.GiaVe" data-bustype="@(ticket.HangXe == BusClass.Premium ? "vip" : "standard")" data-rating="@rating.ToString("F1")" data-departure="@ticket.NgayDi.ToString("yyyy-MM-ddTHH:mm")">
                            <!-- Image -->
                            <div class="card-image">
                                <div class="card-image-placeholder">🚌</div>
                            </div>

                            <!-- Info -->
                            <div class="card-info">
                                <!-- Header: Company & Rating -->
                                <div class="card-header">
                                    <div class="bus-company">
                                        <span class="company-logo">VX</span>
                                        <span class="company-name">Vé Xe Miền Đông</span>
                                    </div>
                                    <div class="rating">
                                        <span class="rating-stars">★ @rating.ToString("F1")</span>
                                        <span class="rating-count">(@ticket.HangXe.ToString())</span>
                                    </div>
                                </div>

                                <!-- Bus Type -->
                                <div class="bus-type">@(ticket.HangXe == BusClass.Premium ? "Xe Cao Cấp VIP" : "Xe Tiêu Chuẩn") 40 Chỗ</div>

                                <!-- Trip Details -->
                                <div class="trip-details">
                                    <div class="trip-time">
                                        <div class="time-badge">
                                            <div class="time">@ticket.NgayDi.ToString("HH:mm")</div>
                                            <div class="location-point">@ticket.DiemDi</div>
                                        </div>
                                    </div>
                                    <div class="trip-time">
                                        <div class="time-badge">
                                            <div class="time">@ticket.NgayDi.AddHours(5).ToString("HH:mm")</div>
                                            <div class="location-point">@ticket.DiemDen</div>
                                        </div>
                                    </div>
                                </div>

                                <div class="duration" style="text-align: center;">⏱ 5h 30m</div>

                                <!-- Amenities -->
                                <div class="amenities">
                                    <span class="amenity-tag">📶 WiFi</span>
                                    <span class="amenity-tag">🚽 Toilet</span>
                                    <span class="amenity-tag highlight">💧 Nước</span>
                                </div>
                            </div>

                            <!-- Action -->
                            <div class="card-action">
                                <div class="price">
                                    <div class="price-label">Từ</div>
                                    <div class="price-value">@ticket.GiaVe.ToString("N0")đ</div>
                                </div>
                                <div class="seats-remaining">
                                    Còn <span class="seats-count">39</span> chỗ
                                </div>
                                <button type="button" class="choose-btn" onclick="showSeatSelector(this, '@ticket.DiemDi', '@ticket.DiemDen', '@ticket.NgayDi.ToString("yyyy-MM-dd HH:mm:ss")', '@ticket.GiaVe')">Chọn Chuyến</button>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="empty-state">
                        <div class="empty-icon">🔍</div>
                        <div class="empty-title">Không tìm thấy chuyến xe</div>
                        <div class="empty-text">Vui lòng thử thay đổi ngày, nơi xuất phát hoặc nơi đến.</div>
                    </div>
                }
            </div>

            <!-- Inline Seat Selector Section -->
            <div id="seatSelectorContainer" class="seat-selector-container" style="display: none;">
                <div class="seat-selector-header">
                    <h2>Chọn Ghế - <span id="seatTripInfo"></span></h2>
                    <button type="button" class="close-seat-selector" onclick="closeSeatSelector()">✕</button>
                </div>

                <div class="seat-selector-content">
                    <!-- Trip Info Summary -->
                    <div class="trip-summary">
                        <div class="trip-info-item">
                            <span class="trip-label">Tuyến đường:</span>
                            <span class="trip-value" id="seatTripRoute"></span>
                        </div>
                        <div class="trip-info-item">
                            <span class="trip-label">Ngày giờ:</span>
                            <span class="trip-value" id="seatTripDateTime"></span>
                        </div>
                        <div class="trip-info-item">
                            <span class="trip-label">Giá vé:</span>
                            <span class="trip-value" id="seatTripPrice"></span>
                        </div>
                    </div>

                    <!-- Seat Map -->
                    <div class="seat-map-wrapper">
                        <div class="seat-legend">
                            <div class="legend-item">
                                <span class="legend-color available"></span>
                                <span>Ghế trống</span>
                            </div>
                            <div class="legend-item">
                                <span class="legend-color selected"></span>
                                <span>Ghế đã chọn</span>
                            </div>
                            <div class="legend-item">
                                <span class="legend-color booked"></span>
                                <span>Ghế đã bán</span>
                            </div>
                        </div>

                        <div class="seat-map">
                            <!-- Bus driver -->
                            <div class="driver-seat">🚘</div>

                            <!-- Seats Grid -->
                            <div class="seats-grid" id="seatsGrid">
                                <!-- Generated by JavaScript -->
                            </div>
                        </div>
                    </div>

                    <!-- Selected Seats Info -->
                    <div class="selected-seats-info">
                        <div class="selected-seats-count">
                            Đã chọn: <span id="selectedSeatsCount">0</span> ghế
                        </div>
                        <div class="selected-seats-list" id="selectedSeatsList"></div>
                    </div>

                    <!-- Purchase Summary Section -->
                    <div class="purchase-summary">
                        <div class="summary-item">
                            <span class="summary-label">Số lượng ghế:</span>
                            <span class="summary-value" id="summarySeats">0</span>
                        </div>
                        <div class="summary-divider"></div>
                        <div class="summary-item total">
                            <span class="summary-label">Tổng cộng:</span>
                            <span class="summary-value total-price" id="totalPrice">0đ</span>
                        </div>
                    </div>

                    <!-- Action Buttons Wrapper -->
                    <div style="display: flex; gap: 12px; align-items: center; width: 100%; box-sizing: border-box; padding: 16px 24px; background: #f9fafb; border-top: 1px solid #e5e7eb; border-radius: 0 0 10px 10px;">
                        <!-- Continue Button Form -->
                        <form method="post" action="/Ticket/SelectBusClass" id="continueForm" style="flex: 1;">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="diemDi" id="formDiemDi">
                            <input type="hidden" name="diemDen" id="formDiemDen">
                            <input type="hidden" name="ngayGio" id="formNgayGio">
                            <input type="hidden" name="selectedSeats" id="formSelectedSeats">
                            <input type="hidden" name="submitType" value="selectBusClass">
                            <button type="submit" id="continueButton" disabled style="flex: 1; background: linear-gradient(135deg, #3b82f6 0%, #1e40af 100%); color: white; padding: 12px 20px; border: none; border-radius: 8px; font-weight: 700; cursor: not-allowed; display: flex; align-items: center; justify-content: center; gap: 8px; transition: all 0.3s; opacity: 0.6; width: 100%;">
                                <span>➜</span>
                                <span>Tiếp Tục</span>
                            </button>
                        </form>

                        <!-- Checkout Button (will add to cart then redirect) -->
                        <button type="button" id="checkoutButton" disabled style="flex: 1; background: linear-gradient(135deg, #10b981 0%, #059669 100%); color: white; padding: 12px 20px; border: none; border-radius: 8px; font-weight: 700; cursor: not-allowed; display: flex; align-items: center; justify-content: center; gap: 8px; transition: all 0.3s; opacity: 0.6; width: 100%;" onclick="handleCheckout()">
                            <span>💳</span>
                            <span>Thanh Toán</span>
                        </button>
                    </div>
                </div>
            </div>
        </section>
    </div>
</div>

<script>
    // Track selected seats
    let selectedSeats = [];
    let currentTrip = null;

    function toggleFilter(element) {
        const icon = element.querySelector('.expand-icon');
        const options = element.nextElementSibling;

        if (icon.classList.contains('expanded')) {
            icon.classList.remove('expanded');
            options.style.display = 'none';
        } else {
            icon.classList.add('expanded');
            options.style.display = 'flex';
        }
    }

    function sortResults(type) {
        const container = document.getElementById('resultsContainer');
        const cards = Array.from(container.querySelectorAll('.result-card'));

        cards.sort((a, b) => {
            const priceA = parseFloat(a.dataset.price);
            const priceB = parseFloat(b.dataset.price);
            const depA = new Date(a.dataset.departure);
            const depB = new Date(b.dataset.departure);

            switch (type) {
                case 'price-asc': return priceA - priceB;
                case 'price-desc': return priceB - priceA;
                case 'time-asc': return depA - depB;
                default: return 0;
            }
        });

        // Re-append sorted cards
        cards.forEach(card => container.appendChild(card));

        // Update active button
        document.querySelectorAll('.sort-btn').forEach(btn => btn.classList.remove('active'));
        event.target.classList.add('active');
    }

    // ===== SIDEBAR FILTER SYSTEM =====
    function applyFilters() {
        const cards = document.querySelectorAll('.result-card');
        let visibleCount = 0;

        // 1. Get price range
        const maxPrice = parseInt(document.getElementById('maxPrice')?.value || '99999999');
        const minPrice = parseInt(document.getElementById('minPrice')?.value || '0');

        // 2. Get selected bus types
        const busTypeChecks = document.querySelectorAll('.filter-section input[value="limousine"], .filter-section input[value="giuong"], .filter-section input[value="thuong"]');
        const selectedBusTypes = [];
        busTypeChecks.forEach(cb => {
            if (cb.checked) selectedBusTypes.push(cb.value);
        });

        // Map filter values to data attributes
        const busTypeMap = {
            'limousine': 'vip',
            'giuong': 'vip',
            'thuong': 'standard'
        };

        // 3. Get selected amenities
        const amenityChecks = document.querySelectorAll('.filter-section input[value="wifi"], .filter-section input[value="toilet"], .filter-section input[value="water"], .filter-section input[value="food"]');
        const selectedAmenities = [];
        amenityChecks.forEach(cb => {
            if (cb.checked) selectedAmenities.push(cb.value);
        });

        // 4. Get rating filter
        const ratingChecks = document.querySelectorAll('.filter-section input[value="5star"], .filter-section input[value="4star"], .filter-section input[value="3star"]');
        const selectedRatings = [];
        ratingChecks.forEach(cb => {
            if (cb.checked) selectedRatings.push(cb.value);
        });

        // Apply filters to each card
        cards.forEach(card => {
            let visible = true;
            const cardPrice = parseFloat(card.dataset.price);
            const cardBusType = card.dataset.bustype;
            const cardRating = parseFloat(card.dataset.rating);

            // Price filter
            if (cardPrice < minPrice || cardPrice > maxPrice) {
                visible = false;
            }

            // Bus type filter (only apply if at least one is checked)
            if (selectedBusTypes.length > 0) {
                const matchedTypes = selectedBusTypes.map(t => busTypeMap[t] || t);
                if (!matchedTypes.includes(cardBusType)) {
                    visible = false;
                }
            }

            // Rating filter
            if (selectedRatings.length > 0) {
                let ratingMatch = false;
                selectedRatings.forEach(r => {
                    if (r === '5star' && cardRating >= 4.5) ratingMatch = true;
                    if (r === '4star' && cardRating >= 4.0 && cardRating < 4.5) ratingMatch = true;
                    if (r === '3star' && cardRating >= 3.5 && cardRating < 4.0) ratingMatch = true;
                });
                if (!ratingMatch) visible = false;
            }

            // Amenity filter - all cards have WiFi, Toilet, Water by default
            // Only "food" is not available, so if food is checked → hide cards
            if (selectedAmenities.includes('food')) {
                visible = false; // No cards have food amenity
            }

            // Show/hide
            card.style.display = visible ? '' : 'none';
            if (visible) visibleCount++;
        });

        // Update results count
        document.getElementById('resultsCount').textContent = `Kết quả: ${visibleCount} chuyến xe`;
    }

    // Attach filter listeners to all checkboxes and inputs
    document.addEventListener('DOMContentLoaded', function() {
        // Price range slider
        const priceRange = document.getElementById('priceRange');
        const maxPriceInput = document.getElementById('maxPrice');
        const minPriceInput = document.getElementById('minPrice');

        if (priceRange) {
            priceRange.addEventListener('input', function() {
                maxPriceInput.value = this.value;
                applyFilters();
            });
        }
        if (maxPriceInput) {
            maxPriceInput.addEventListener('change', function() {
                if (priceRange) priceRange.value = this.value;
                applyFilters();
            });
        }
        if (minPriceInput) {
            minPriceInput.addEventListener('change', applyFilters);
        }

        // All filter checkboxes
        document.querySelectorAll('.filter-options input[type="checkbox"]').forEach(cb => {
            cb.addEventListener('change', applyFilters);
        });
    });

    // Seat Selector Functions
    function showSeatSelector(button, diemDi, diemDen, ngayGio, giaVe) {
        selectedSeats = [];
        currentTrip = { diemDi, diemDen, ngayGio, giaVe };

        // Update form hidden fields
        document.getElementById('formDiemDi').value = diemDi;
        document.getElementById('formDiemDen').value = diemDen;
        document.getElementById('formNgayGio').value = ngayGio;

        // Update trip info display
        const date = new Date(ngayGio);
        document.getElementById('seatTripInfo').textContent = `${diemDi} → ${diemDen}`;
        document.getElementById('seatTripRoute').textContent = `${diemDi} → ${diemDen}`;
        document.getElementById('seatTripDateTime').textContent = date.toLocaleString('vi-VN');
        document.getElementById('seatTripPrice').textContent = `${parseInt(giaVe).toLocaleString('vi-VN')}đ`;

        // Generate seat map
        generateSeatMap();

        // Show container and scroll to it
        const container = document.getElementById('seatSelectorContainer');
        container.style.display = 'block';

        // Animate slide down
        container.classList.remove('hidden');
        container.classList.add('visible');

        // Scroll to seat selector
        setTimeout(() => {
            container.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }, 100);

        console.log('✅ Seat selector opened for:', diemDi, diemDen);
    }

    function closeSeatSelector() {
        const container = document.getElementById('seatSelectorContainer');
        container.classList.remove('visible');
        container.classList.add('hidden');

        setTimeout(() => {
            container.style.display = 'none';
            selectedSeats = [];
            document.getElementById('selectedSeatsCount').textContent = '0';
            document.getElementById('selectedSeatsList').innerHTML = '';
        }, 300);
    }

    function setSubmitType(type) {
        document.getElementById('submitTypeInput').value = type;

        // If checkout is selected and user not logged in, redirect to login
        if (type === 'checkout') {
            const userId = getSessionUserId();
            if (!userId) {
                event.preventDefault();
                // Store the form data to restore after login
                const formData = {
                    diemDi: document.getElementById('formDiemDi').value,
                    diemDen: document.getElementById('formDiemDen').value,
                    ngayGio: document.getElementById('formNgayGio').value,
                    selectedSeats: document.getElementById('formSelectedSeats').value
                };
                sessionStorage.setItem('checkoutFormData', JSON.stringify(formData));
                window.location.href = '/Account/Login';
                return false;
            }
        }
    }

    function getSessionUserId() {
        // Check if user is logged in by looking for a data attribute in the page
        // This should be set by the server in the layout
        const userElement = document.querySelector('[data-user-id]');
        return userElement ? userElement.getAttribute('data-user-id') : null;
    }

    function generateSeatMap() {
        const seatsGrid = document.getElementById('seatsGrid');
        seatsGrid.innerHTML = '';
        selectedSeats = [];

        // Generate 40 seats (8 rows x 5 columns - typical bus layout)
        const rows = 8;
        const cols = 5;
        const bookedSeats = [3, 7, 12, 15, 22, 28, 35, 38]; // Sample booked seats

        for (let i = 1; i <= rows * cols; i++) {
            const seatDiv = document.createElement('div');
            seatDiv.className = 'seat';
            seatDiv.textContent = i;

            // Check if seat is booked
            if (bookedSeats.includes(i)) {
                seatDiv.classList.add('booked');
                seatDiv.style.pointerEvents = 'none';
            } else {
                seatDiv.addEventListener('click', function () {
                    toggleSeatSelection(this, i);
                });
                seatDiv.style.cursor = 'pointer';
            }

            seatsGrid.appendChild(seatDiv);
        }
    }

    function toggleSeatSelection(seatElement, seatNumber) {
        if (seatElement.classList.contains('booked')) return;

        if (seatElement.classList.contains('selected')) {
            seatElement.classList.remove('selected');
            selectedSeats = selectedSeats.filter(s => s !== seatNumber);
        } else {
            seatElement.classList.add('selected');
            selectedSeats.push(seatNumber);
        }

        updateSelectedSeatsDisplay();
    }

    function updateSelectedSeatsDisplay() {
        document.getElementById('selectedSeatsCount').textContent = selectedSeats.length;
        document.getElementById('summarySeats').textContent = selectedSeats.length;

        const selectedList = document.getElementById('selectedSeatsList');
        const continueButton = document.getElementById('continueButton');
        const checkoutButton = document.getElementById('checkoutButton');

        // Calculate and display total price
        if (selectedSeats.length > 0) {
            selectedList.innerHTML = '<strong>Ghế:</strong> ' + selectedSeats.sort((a, b) => a - b).join(', ');

            // Update continue form fields
            document.getElementById('formSelectedSeats').value = selectedSeats.join(',');

            // Calculate total price
            const ticketPrice = parseInt(currentTrip.giaVe);
            const totalPrice = selectedSeats.length * ticketPrice;
            document.getElementById('totalPrice').textContent = totalPrice.toLocaleString('vi-VN') + 'đ';

            // Enable continue buttons
            continueButton.disabled = false;
            checkoutButton.disabled = false;

            // Update button styles when enabled
            continueButton.style.opacity = '1';
            continueButton.style.cursor = 'pointer';
            checkoutButton.style.opacity = '1';
            checkoutButton.style.cursor = 'pointer';
        } else {
            selectedList.innerHTML = '';
            document.getElementById('formSelectedSeats').value = '';

            // Reset summary display
            document.getElementById('totalPrice').textContent = '0đ';

            // Disable continue buttons
            continueButton.disabled = true;
            checkoutButton.disabled = true;

            // Reset button styles when disabled
            continueButton.style.opacity = '0.6';
            continueButton.style.cursor = 'not-allowed';
            checkoutButton.style.opacity = '0.6';
            checkoutButton.style.cursor = 'not-allowed';
        }
    }

    // Update price filter display
    document.getElementById('priceRange')?.addEventListener('input', function() {
        document.getElementById('maxPrice').value = this.value;
    });

    // Update results count
    window.addEventListener('load', function() {
        const cardCount = document.querySelectorAll('.result-card').length;
        document.getElementById('resultsCount').textContent = `Kết quả: ${cardCount} chuyến xe`;
    });

    // Handle checkout - add to cart then redirect
    function handleCheckout() {
        if (!currentTrip) {
            alert('Vui lòng chọn chuyến xe');
            return;
        }

        if (selectedSeats.length === 0) {
            alert('Vui lòng chọn ghế');
            return;
        }

        const diemDi = document.getElementById('formDiemDi').value;
        const diemDen = document.getElementById('formDiemDen').value;
        const ngayGio = document.getElementById('formNgayGio').value;
        const selectedSeatsList = selectedSeats.join(', ');
        const ticketPrice = parseInt(currentTrip.giaVe);
        const totalPrice = selectedSeats.length * ticketPrice;

        // Create route string
        const route = `${diemDi} → ${diemDen}`;

        // Build the AddToCart URL with parameters
        const params = new URLSearchParams({
            ticketCode: `VE-${Date.now()}`,
            route: route,
            seats: selectedSeatsList,
            price: ticketPrice,
            busClass: 'Standard',
            departureTime: ngayGio
        });

        // First, add to cart
        fetch(`/Cart/AddToCart?${params.toString()}`, {
            method: 'GET',
            headers: {
                'Content-Type': 'application/json'
            }
        })
        .then(response => {
            if (response.ok) {
                // After successfully adding to cart, redirect to checkout
                window.location.href = '/Checkout/Index';
            } else {
                alert('Lỗi khi thêm vào giỏ hàng');
            }
        })
        .catch(error => {
            console.error('Error:', error);
            alert('Lỗi: ' + error.message);
        });
    }
</script>

