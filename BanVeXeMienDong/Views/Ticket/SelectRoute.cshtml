@model List<BanVeXeMienDong.Models.Ticket>
@using BanVeXeMienDong.Models

@{
    ViewData["Title"] = "Tìm chuyến xe";
}

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
    <!-- Search Bar -->
    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-5 mb-6">
        <form method="get" action="/Ticket/SelectRoute" class="grid grid-cols-1 md:grid-cols-12 gap-4 items-end">
            <div class="md:col-span-3">
                <label class="block text-xs font-semibold text-gray-500 mb-1 uppercase">Điểm đi</label>
                <select name="diemDi" class="w-full px-4 py-2.5 border-2 border-gray-200 rounded-xl text-sm focus:border-blue-500 focus:ring-2 focus:ring-blue-100">
                    <option value="">-- Chọn --</option>
                    @if (ViewBag.Routes != null)
                    {
                        var fromPoints = ((IEnumerable<dynamic>)ViewBag.Routes).Select(r => (string)r.DiemDi).Distinct();
                        foreach (var p in fromPoints)
                        {
                            <option value="@p" selected="@(ViewBag.DiemDi == p)">@p</option>
                        }
                    }
                </select>
            </div>
            <div class="md:col-span-3">
                <label class="block text-xs font-semibold text-gray-500 mb-1 uppercase">Điểm đến</label>
                <select name="diemDen" class="w-full px-4 py-2.5 border-2 border-gray-200 rounded-xl text-sm focus:border-blue-500 focus:ring-2 focus:ring-blue-100">
                    <option value="">-- Chọn --</option>
                    @if (ViewBag.Routes != null)
                    {
                        var toPoints = ((IEnumerable<dynamic>)ViewBag.Routes).Select(r => (string)r.DiemDen).Distinct();
                        foreach (var p in toPoints)
                        {
                            <option value="@p" selected="@(ViewBag.DiemDen == p)">@p</option>
                        }
                    }
                </select>
            </div>
            <div class="md:col-span-3">
                <label class="block text-xs font-semibold text-gray-500 mb-1 uppercase">Ngày đi</label>
                <input type="date" name="ngayDi" value="@ViewBag.NgayDi" class="w-full px-4 py-2.5 border-2 border-gray-200 rounded-xl text-sm focus:border-blue-500 focus:ring-2 focus:ring-blue-100">
            </div>
            <div class="md:col-span-3 flex gap-2">
                <button type="submit" class="flex-1 py-2.5 bg-yellow-400 hover:bg-yellow-500 text-yellow-900 font-bold rounded-xl text-sm transition-all">
                    <i class="bi bi-search"></i> Tìm
                </button>
                <a href="/Ticket/SelectRoute" class="py-2.5 px-4 bg-gray-200 hover:bg-gray-300 text-gray-700 font-medium rounded-xl text-sm transition-all">
                    <i class="bi bi-x-lg"></i>
                </a>
            </div>
        </form>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-4 gap-6">
        <!-- Sidebar Filters -->
        <aside class="lg:col-span-1">
            <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-5 sticky top-20 space-y-5">
                <h3 class="font-bold text-gray-900 text-sm uppercase tracking-wide">Bộ Lọc</h3>

                <!-- Price -->
                <div>
                    <h4 class="text-sm font-semibold text-gray-700 mb-2">Giá Vé</h4>
                    <div class="flex gap-2">
                        <input type="number" id="minPrice" placeholder="Min" value="0" class="w-1/2 px-2 py-1.5 border border-gray-200 rounded-lg text-xs">
                        <input type="number" id="maxPrice" placeholder="Max" value="5000000" class="w-1/2 px-2 py-1.5 border border-gray-200 rounded-lg text-xs">
                    </div>
                    <input type="range" id="priceRange" min="0" max="5000000" value="5000000" step="50000" class="w-full mt-2 accent-blue-600">
                    <div class="text-xs text-gray-400 mt-1">Tối đa: <span id="priceDisplay">5.000.000</span>đ</div>
                </div>

                <!-- Bus Type -->
                <div>
                    <h4 class="text-sm font-semibold text-gray-700 mb-2">Loại Xe</h4>
                    <label class="flex items-center gap-2 mb-1.5 cursor-pointer">
                        <input type="checkbox" value="standard" class="filter-bustype w-4 h-4 rounded border-gray-300 text-blue-600">
                        <span class="text-sm text-gray-600">Xe Thường</span>
                    </label>
                    <label class="flex items-center gap-2 cursor-pointer">
                        <input type="checkbox" value="vip" class="filter-bustype w-4 h-4 rounded border-gray-300 text-blue-600">
                        <span class="text-sm text-gray-600">Xe VIP / Cao Cấp</span>
                    </label>
                </div>

                <!-- Rating -->
                <div>
                    <h4 class="text-sm font-semibold text-gray-700 mb-2">Đánh Giá</h4>
                    <label class="flex items-center gap-2 mb-1.5 cursor-pointer">
                        <input type="checkbox" value="4.5" class="filter-rating w-4 h-4 rounded border-gray-300 text-blue-600">
                        <span class="text-sm text-gray-600">⭐ 4.5+</span>
                    </label>
                    <label class="flex items-center gap-2 cursor-pointer">
                        <input type="checkbox" value="4.0" class="filter-rating w-4 h-4 rounded border-gray-300 text-blue-600">
                        <span class="text-sm text-gray-600">⭐ 4.0+</span>
                    </label>
                </div>

                <button onclick="applyFilters()" class="w-full py-2 bg-blue-600 hover:bg-blue-700 text-white text-sm font-semibold rounded-xl transition-all">
                    Áp Dụng Lọc
                </button>
            </div>
        </aside>

        <!-- Results -->
        <section class="lg:col-span-3">
            <!-- Toolbar -->
            <div class="flex items-center justify-between mb-4">
                <span id="resultsCount" class="text-sm text-gray-500 font-medium"></span>
                <div class="flex gap-1">
                    <button onclick="sortResults('default')" class="sort-btn px-3 py-1.5 text-xs font-medium bg-blue-100 text-blue-700 rounded-lg">Mặc định</button>
                    <button onclick="sortResults('price-asc')" class="sort-btn px-3 py-1.5 text-xs font-medium bg-gray-100 text-gray-600 rounded-lg hover:bg-blue-100 hover:text-blue-700">Giá thấp</button>
                    <button onclick="sortResults('price-desc')" class="sort-btn px-3 py-1.5 text-xs font-medium bg-gray-100 text-gray-600 rounded-lg hover:bg-blue-100 hover:text-blue-700">Giá cao</button>
                    <button onclick="sortResults('time-asc')" class="sort-btn px-3 py-1.5 text-xs font-medium bg-gray-100 text-gray-600 rounded-lg hover:bg-blue-100 hover:text-blue-700">Sớm nhất</button>
                </div>
            </div>

            <!-- Result Cards -->
            <div id="resultsContainer" class="space-y-4">
                @if (Model != null && Model.Count > 0)
                {
                    foreach (var ticket in Model)
                    {
                        var rating = (4.2 + (ticket.Id % 8) * 0.1).ToString("F1");
                        var busTypeStr = ticket.HangXe == BusClass.Premium ? "vip" : "standard";
                        var busTypeName = ticket.HangXe == BusClass.Premium ? "Xe Cao Cấp VIP" : "Xe Tiêu Chuẩn";

                        <div class="result-card bg-white rounded-xl border border-gray-100 shadow-sm hover:shadow-md transition-all overflow-hidden"
                             data-price="@ticket.GiaVe" data-bustype="@busTypeStr" data-rating="@rating" data-departure="@ticket.NgayDi.ToString("yyyy-MM-ddTHH:mm")">
                            <div class="flex flex-col sm:flex-row">
                                <!-- Left: Info -->
                                <div class="flex-1 p-5">
                                    <div class="flex items-center gap-3 mb-3">
                                        <div class="w-10 h-10 rounded-xl bg-blue-100 flex items-center justify-center">
                                            <i class="bi bi-bus-front text-blue-600"></i>
                                        </div>
                                        <div>
                                            <div class="font-semibold text-gray-900 text-sm">Bến Xe Miền Đông</div>
                                            <div class="text-xs text-gray-400">@busTypeName</div>
                                        </div>
                                        <div class="ml-auto flex items-center gap-1 bg-green-50 px-2 py-1 rounded-lg">
                                            <span class="text-xs font-bold text-green-700">⭐ @rating</span>
                                        </div>
                                    </div>

                                    <!-- Route & Time -->
                                    <div class="flex items-center gap-4 mb-3">
                                        <div class="text-center">
                                            <div class="text-lg font-bold text-gray-900">@ticket.NgayDi.ToString("HH:mm")</div>
                                            <div class="text-xs text-gray-400">@ticket.DiemDi</div>
                                        </div>
                                        <div class="flex-1 flex items-center gap-2">
                                            <div class="h-px bg-gray-300 flex-1"></div>
                                            <span class="text-xs text-gray-400 whitespace-nowrap">~5h30</span>
                                            <div class="h-px bg-gray-300 flex-1"></div>
                                        </div>
                                        <div class="text-center">
                                            <div class="text-lg font-bold text-gray-900">@ticket.NgayDi.AddHours(5).ToString("HH:mm")</div>
                                            <div class="text-xs text-gray-400">@ticket.DiemDen</div>
                                        </div>
                                    </div>

                                    <!-- Tags -->
                                    <div class="flex flex-wrap gap-1.5">
                                        <span class="px-2 py-0.5 bg-blue-50 text-blue-700 rounded text-xs font-medium">WiFi</span>
                                        <span class="px-2 py-0.5 bg-blue-50 text-blue-700 rounded text-xs font-medium">Nước uống</span>
                                        <span class="px-2 py-0.5 bg-blue-50 text-blue-700 rounded text-xs font-medium">@ticket.NgayDi.ToString("dd/MM/yyyy")</span>
                                        @if (ticket.HangXe == BusClass.Premium)
                                        {
                                            <span class="px-2 py-0.5 bg-yellow-50 text-yellow-700 rounded text-xs font-medium">VIP</span>
                                        }
                                    </div>
                                </div>

                                <!-- Right: Price & Action -->
                                <div class="sm:w-48 p-5 bg-gray-50 sm:border-l border-t sm:border-t-0 border-gray-100 flex flex-col items-center justify-center gap-2">
                                    <div class="text-xs text-gray-400">Giá từ</div>
                                    <div class="text-2xl font-black text-blue-600">@ticket.GiaVe.ToString("N0")đ</div>
                                    <div class="text-xs text-gray-400">Còn 39 chỗ</div>
                                    <button type="button" onclick="showSeatSelector('@ticket.DiemDi', '@ticket.DiemDen', '@ticket.NgayDi.ToString("yyyy-MM-dd HH:mm:ss")', '@ticket.GiaVe')"
                                        class="w-full mt-2 py-2.5 bg-gradient-to-r from-blue-600 to-blue-700 hover:from-blue-700 hover:to-blue-800 text-white text-sm font-bold rounded-xl shadow-sm hover:shadow-md transition-all">
                                        Chọn Chuyến
                                    </button>
                                </div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="text-center py-20">
                        <i class="bi bi-search text-5xl text-gray-300"></i>
                        <h3 class="text-lg font-semibold text-gray-700 mt-4">Không tìm thấy chuyến xe</h3>
                        <p class="text-sm text-gray-400 mt-1">Vui lòng thử thay đổi điểm đi, điểm đến hoặc ngày.</p>
                    </div>
                }
            </div>
        </section>
    </div>
</div>

<!-- Seat Selector Modal -->
<div id="seatModal" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4">
    <div class="absolute inset-0 bg-black/50 backdrop-blur-sm" onclick="closeSeatSelector()"></div>
    <div class="relative bg-white rounded-2xl shadow-2xl w-full max-w-lg max-h-[90vh] overflow-y-auto">
        <!-- Header -->
        <div class="gradient-primary p-5 text-white sticky top-0 z-10">
            <div class="flex items-center justify-between">
                <h2 class="font-bold text-lg" id="seatModalTitle">Chọn Ghế</h2>
                <button onclick="closeSeatSelector()" class="w-8 h-8 rounded-full bg-white/20 flex items-center justify-center hover:bg-white/30 transition-all">&times;</button>
            </div>
            <div class="text-sm text-blue-100 mt-1" id="seatModalRoute"></div>
        </div>

        <div class="p-5">
            <!-- Trip Info -->
            <div class="grid grid-cols-3 gap-3 mb-5">
                <div class="text-center p-3 bg-gray-50 rounded-xl">
                    <div class="text-xs text-gray-400">Tuyến</div>
                    <div class="font-semibold text-sm mt-0.5" id="seatInfoRoute">-</div>
                </div>
                <div class="text-center p-3 bg-gray-50 rounded-xl">
                    <div class="text-xs text-gray-400">Ngày giờ</div>
                    <div class="font-semibold text-sm mt-0.5" id="seatInfoDate">-</div>
                </div>
                <div class="text-center p-3 bg-gray-50 rounded-xl">
                    <div class="text-xs text-gray-400">Giá/ghế</div>
                    <div class="font-semibold text-sm mt-0.5 text-blue-600" id="seatInfoPrice">-</div>
                </div>
            </div>

            <!-- Legend -->
            <div class="flex justify-center gap-4 mb-4">
                <div class="flex items-center gap-1.5"><div class="w-6 h-6 rounded-lg bg-gray-100 border-2 border-gray-200"></div><span class="text-xs text-gray-500">Trống</span></div>
                <div class="flex items-center gap-1.5"><div class="w-6 h-6 rounded-lg bg-blue-600 border-2 border-blue-600"></div><span class="text-xs text-gray-500">Đã chọn</span></div>
                <div class="flex items-center gap-1.5"><div class="w-6 h-6 rounded-lg bg-gray-400 border-2 border-gray-400"></div><span class="text-xs text-gray-500">Đã bán</span></div>
            </div>

            <!-- Seat Map -->
            <div class="bg-gray-50 rounded-xl p-4">
                <div class="text-center text-gray-400 text-xs mb-3">🚘 Tài xế</div>
                <div id="seatGrid" class="grid grid-cols-5 gap-2 max-w-[250px] mx-auto"></div>
            </div>

            <!-- Summary -->
            <div class="mt-5 p-4 bg-blue-50 rounded-xl border border-blue-100">
                <div class="flex items-center justify-between">
                    <div>
                        <span class="text-sm text-gray-600">Đã chọn: <strong id="seatCount">0</strong> ghế</span>
                        <div class="text-xs text-gray-400 mt-0.5" id="seatList">-</div>
                    </div>
                    <div class="text-right">
                        <div class="text-xs text-gray-400">Tổng cộng</div>
                        <div class="text-xl font-black text-blue-600" id="seatTotal">0đ</div>
                    </div>
                </div>
            </div>

            <!-- Actions -->
            <form method="post" action="/Ticket/SelectBusClass" id="seatForm" class="mt-5 grid grid-cols-2 gap-3">
                @Html.AntiForgeryToken()
                <input type="hidden" name="diemDi" id="formDiemDi">
                <input type="hidden" name="diemDen" id="formDiemDen">
                <input type="hidden" name="ngayGio" id="formNgayGio">
                <input type="hidden" name="selectedSeats" id="formSelectedSeats">
                <input type="hidden" name="submitType" id="formSubmitType" value="selectBusClass">

                <button type="submit" id="btnContinue" disabled class="py-3 bg-blue-600 hover:bg-blue-700 disabled:bg-gray-300 disabled:cursor-not-allowed text-white font-semibold rounded-xl transition-all text-sm">
                    <i class="bi bi-arrow-right"></i> Tiếp tục
                </button>
                <button type="button" id="btnCheckout" disabled onclick="handleCheckout()" class="py-3 bg-green-600 hover:bg-green-700 disabled:bg-gray-300 disabled:cursor-not-allowed text-white font-semibold rounded-xl transition-all text-sm">
                    <i class="bi bi-credit-card"></i> Thanh toán
                </button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
    // === DATA ===
    let selectedSeats = [];
    let currentTrip = null;
    const bookedSample = [3, 7, 12, 15, 22, 28, 35, 38];

    // === SEAT SELECTOR ===
    function showSeatSelector(diemDi, diemDen, ngayGio, giaVe) {
        selectedSeats = [];
        currentTrip = { diemDi, diemDen, ngayGio, giaVe: parseInt(giaVe) };

        document.getElementById('formDiemDi').value = diemDi;
        document.getElementById('formDiemDen').value = diemDen;
        document.getElementById('formNgayGio').value = ngayGio;

        const route = `${diemDi} → ${diemDen}`;
        document.getElementById('seatModalTitle').textContent = `Chọn Ghế - ${route}`;
        document.getElementById('seatModalRoute').textContent = new Date(ngayGio).toLocaleDateString('vi-VN');
        document.getElementById('seatInfoRoute').textContent = route;
        document.getElementById('seatInfoDate').textContent = new Date(ngayGio).toLocaleString('vi-VN', { day: '2-digit', month: '2-digit', hour: '2-digit', minute: '2-digit' });
        document.getElementById('seatInfoPrice').textContent = parseInt(giaVe).toLocaleString('vi-VN') + 'đ';

        generateSeats();
        updateSeatSummary();
        document.getElementById('seatModal').classList.remove('hidden');
        document.body.style.overflow = 'hidden';
    }

    function closeSeatSelector() {
        document.getElementById('seatModal').classList.add('hidden');
        document.body.style.overflow = '';
    }

    function generateSeats() {
        const grid = document.getElementById('seatGrid');
        grid.innerHTML = '';
        for (let i = 1; i <= 40; i++) {
            const isBooked = bookedSample.includes(i);
            const seat = document.createElement('button');
            seat.type = 'button';
            seat.textContent = i;
            seat.className = isBooked
                ? 'w-full aspect-square rounded-lg bg-gray-400 text-white text-xs font-bold cursor-not-allowed'
                : 'w-full aspect-square rounded-lg bg-gray-100 border-2 border-gray-200 text-xs font-bold text-gray-600 hover:border-blue-400 hover:bg-blue-50 transition-all seat-available';
            if (!isBooked) {
                seat.addEventListener('click', () => toggleSeat(seat, i));
            }
            grid.appendChild(seat);
        }
    }

    function toggleSeat(el, num) {
        if (el.classList.contains('seat-selected')) {
            el.classList.remove('seat-selected', 'bg-blue-600', 'border-blue-600', 'text-white');
            el.classList.add('bg-gray-100', 'border-gray-200', 'text-gray-600');
            selectedSeats = selectedSeats.filter(s => s !== num);
        } else {
            el.classList.add('seat-selected', 'bg-blue-600', 'border-blue-600', 'text-white');
            el.classList.remove('bg-gray-100', 'border-gray-200', 'text-gray-600');
            selectedSeats.push(num);
        }
        updateSeatSummary();
    }

    function updateSeatSummary() {
        const count = selectedSeats.length;
        document.getElementById('seatCount').textContent = count;
        document.getElementById('seatList').textContent = count > 0 ? 'Ghế: ' + selectedSeats.sort((a,b)=>a-b).join(', ') : '-';
        document.getElementById('seatTotal').textContent = (count * (currentTrip?.giaVe || 0)).toLocaleString('vi-VN') + 'đ';
        document.getElementById('formSelectedSeats').value = selectedSeats.join(',');

        const enabled = count > 0;
        document.getElementById('btnContinue').disabled = !enabled;
        document.getElementById('btnCheckout').disabled = !enabled;
    }

    function handleCheckout() {
        document.getElementById('formSubmitType').value = 'checkout';
        document.getElementById('seatForm').submit();
    }

    // === FILTERS ===
    function applyFilters() {
        const cards = document.querySelectorAll('.result-card');
        const maxPrice = parseInt(document.getElementById('maxPrice').value) || 99999999;
        const minPrice = parseInt(document.getElementById('minPrice').value) || 0;

        const busTypes = [];
        document.querySelectorAll('.filter-bustype:checked').forEach(cb => busTypes.push(cb.value));

        const ratings = [];
        document.querySelectorAll('.filter-rating:checked').forEach(cb => ratings.push(parseFloat(cb.value)));

        let visible = 0;
        cards.forEach(card => {
            const price = parseFloat(card.dataset.price);
            const type = card.dataset.bustype;
            const rating = parseFloat(card.dataset.rating);

            let show = true;
            if (price < minPrice || price > maxPrice) show = false;
            if (busTypes.length > 0 && !busTypes.includes(type)) show = false;
            if (ratings.length > 0 && !ratings.some(r => rating >= r)) show = false;

            card.style.display = show ? '' : 'none';
            if (show) visible++;
        });

        document.getElementById('resultsCount').textContent = `${visible} chuyến xe`;
    }

    function sortResults(type) {
        const container = document.getElementById('resultsContainer');
        const cards = Array.from(container.querySelectorAll('.result-card'));
        cards.sort((a, b) => {
            if (type === 'price-asc') return parseFloat(a.dataset.price) - parseFloat(b.dataset.price);
            if (type === 'price-desc') return parseFloat(b.dataset.price) - parseFloat(a.dataset.price);
            if (type === 'time-asc') return new Date(a.dataset.departure) - new Date(b.dataset.departure);
            return 0;
        });
        cards.forEach(c => container.appendChild(c));

        document.querySelectorAll('.sort-btn').forEach(b => { b.className = 'sort-btn px-3 py-1.5 text-xs font-medium bg-gray-100 text-gray-600 rounded-lg hover:bg-blue-100 hover:text-blue-700'; });
        event.target.className = 'sort-btn px-3 py-1.5 text-xs font-medium bg-blue-100 text-blue-700 rounded-lg';
    }

    // === PRICE RANGE ===
    const priceRange = document.getElementById('priceRange');
    const maxPriceInput = document.getElementById('maxPrice');
    const priceDisplay = document.getElementById('priceDisplay');

    priceRange?.addEventListener('input', function() {
        maxPriceInput.value = this.value;
        priceDisplay.textContent = parseInt(this.value).toLocaleString('vi-VN');
    });

    // Init count
    window.addEventListener('load', () => {
        const count = document.querySelectorAll('.result-card').length;
        document.getElementById('resultsCount').textContent = `${count} chuyến xe`;
    });
</script>
}
